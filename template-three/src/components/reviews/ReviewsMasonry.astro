---
/**
 * Reviews — editorial masonry wall. Used on the home page.
 *
 * Reviews are separated by generous whitespace and a hairline top divider
 * rather than framed as cards. Keeps the focus on the quotes themselves.
 *
 * One of three review variants in the template — the other pages use
 * ReviewsMarquee and ReviewsFeatured so each page's social proof reads
 * a little differently.
 */
import { business } from "@/data/business";
import GoogleLogo from "@/components/ui/GoogleLogo.astro";
import StarRating from "@/components/ui/StarRating.astro";

interface Review {
  name: string;
  rating: number;
  text: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  rating?: number;
  total?: number;
  reviews?: Review[];
  viewAllHref?: string;
}

const {
  eyebrow = "Google Reviews",
  heading = "Quid nostri clientes dicunt.",
  rating = business.reviews.rating,
  total = business.reviews.total,
  reviews = business.reviews.items,
  viewAllHref = "https://www.google.com/maps",
} = Astro.props;
---

<section class="bg-surface py-20 lg:py-28" aria-label="Customer reviews">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Header — eyebrow, heading, rating summary with Google branding -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14 lg:mb-16">

      <div class="max-w-xl">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}
        <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">{heading}</h2>
      </div>

      <!-- Rating summary with Google logo -->
      <div class="flex items-center gap-4">
        <GoogleLogo class="w-10 h-10" />

        <div class="flex flex-col">
          <div class="flex items-center gap-2">
            <span class="font-heading text-2xl text-text leading-none">{rating.toFixed(1)}</span>
            <StarRating ariaLabel={`${rating} out of 5 stars`} />
          </div>
          <span class="font-body text-sm text-text-soft mt-1">
            {total}+ reviews on <span class="font-semibold text-text">Google</span>
          </span>
        </div>
      </div>

    </div>

    <!-- Masonry reviews — no cards, just hairline tops + typography -->
    <div class="columns-1 sm:columns-2 lg:columns-3 [column-gap:2.5rem] [column-fill:balance]">
      {reviews.map((review) => (
        <article class="break-inside-avoid mb-10 pt-5 border-t border-border">

          <StarRating count={review.rating} class="flex gap-0.5 mb-4" />

          <p class="font-body text-base text-text leading-relaxed">
            &ldquo;{review.text}&rdquo;
          </p>

          <footer class="mt-4 text-sm">
            <span class="font-body font-semibold text-text">— {review.name}</span>
          </footer>

        </article>
      ))}
    </div>

    <!-- View all reviews -->
    <div class="mt-10 text-center">
      <a
        href={viewAllHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
      >
        Read all reviews on Google
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
