---
/**
 * Hero — image on the right, copy on the left.
 *
 * The image column renders an obvious placeholder that makes it clear where
 * a real photo should go. Local-business sites live or die on strong imagery.
 */
import { business } from "@/data/business";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  subtext?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  stats?: Stat[];
  imageSrc?: string;
  imageAlt?: string;
  imageLabel?: string;
}

const {
  eyebrow = "Licensed · Insured · Local",
  headline = "Lorem ipsum dolor sit amet consectetur.",
  subtext = "Adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.",
  primaryCta = { label: business.ctaLabel, href: business.ctaHref },
  secondaryCta = { label: "View Services", href: "/services" },
  stats = business.stats.slice(0, 3),
  imageSrc,
  imageAlt = "Business hero image",
  imageLabel = "Hero Image",
} = Astro.props;

const phoneHref = "tel:+1" + business.phone.replace(/\D/g, "");
---

<section class="relative overflow-hidden bg-surface">
  <!-- Ambient brand glow — ties copy and image together visually -->
  <div
    class="hidden lg:block absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1100px] h-[700px] rounded-full bg-brand/[0.05] blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  {/* Top padding clears the floating nav pill (~4.25rem) + breathing room.
      The section's bg-surface paints the whole area, so the translucent pill
      floats over the hero cleanly — no color break at the top of the page. */}
  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-28 lg:pt-36 pb-16 lg:pb-24">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">

      <!-- Copy -->
      <div class="lg:col-span-6">

        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-6">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h1 class="font-heading text-3xl sm:text-4xl lg:text-hero text-text leading-[1.05] tracking-tight">
          {headline}
        </h1>

        <p class="font-body text-base lg:text-lg text-text-soft mt-6 leading-relaxed max-w-xl">
          {subtext}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-3 mt-9">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center gap-2 bg-brand text-brand-fg font-body font-semibold text-base px-6 py-3.5 rounded-md shadow-sm hover:bg-brand/90 transition-colors"
          >
            {primaryCta.label}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href={phoneHref}
            class="inline-flex items-center gap-2 font-body font-semibold text-text underline decoration-brand decoration-2 underline-offset-[6px] hover:decoration-brand/60 transition-colors"
          >
            <svg class="w-4 h-4 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {business.phone}
          </a>
        </div>

        <!-- Stats row — plain text, no cards -->
        {stats.length > 0 && (
          <dl class="mt-12 pt-8 border-t border-border flex flex-wrap gap-x-10 gap-y-5">
            {stats.map((stat) => (
              <div>
                <dt class="font-heading text-2xl text-text leading-none">{stat.value}</dt>
                <dd class="font-body text-sm text-text-soft mt-2">{stat.label}</dd>
              </div>
            ))}
          </dl>
        )}

      </div>

      <!-- Image placeholder — clearly shows where a real photo goes -->
      <div class="lg:col-span-6">
        <ImagePlaceholder
          aspect="5/4"
          imageSrc={imageSrc}
          imageAlt={imageAlt}
          label={imageLabel}
          hint="A photo of your team, storefront, or best work fits here."
          bloomPosition="tl"
        />
      </div>

    </div>
  </div>
</section>
