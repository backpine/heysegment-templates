---
import { Font } from "astro:assets";
import "@/styles/global.css";
import Nav from "@/components/global/Nav.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  // Core metadata
  title?: string;
  description?: string;
  canonical?: string;

  // Open Graph
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  ogType?: string;
  ogUrl?: string;
  ogSiteName?: string;
  ogLocale?: string;

  // Twitter
  twitterCard?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  twitterSite?: string;

  // Robots & indexing
  robots?: string;

  // Geo
  geoRegion?: string;
  geoPlacename?: string;
  geoPosition?: string; // "latitude;longitude"

  // Theme & branding
  themeColor?: string;
  author?: string;

  // Performance hints
  preconnect?: string[]; // array of URLs to preconnect
  dnsPrefetch?: string[]; // array of URLs to DNS prefetch
}

const {
  title,
  description,
  canonical,

  ogTitle,
  ogDescription,
  ogImage,
  ogImageWidth,
  ogImageHeight,
  ogType,
  ogUrl,
  ogSiteName,
  ogLocale,

  twitterCard,
  twitterTitle,
  twitterDescription,
  twitterImage,
  twitterSite,

  robots,

  geoRegion,
  geoPlacename,
  geoPosition,

  themeColor,
  author,

  preconnect,
  dnsPrefetch,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-provider-body" preload />
    <Font cssVariable="--font-provider-heading" preload />

    {/* Core metadata */}
    {title && <title>{title}</title>}
    {description && <meta name="description" content={description} />}
    {robots && <meta name="robots" content={robots} />}
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Author */}
    {author && <meta name="author" content={author} />}

    {/* Geo targeting */}
    {geoRegion && <meta name="geo.region" content={geoRegion} />}
    {geoPlacename && <meta name="geo.placename" content={geoPlacename} />}
    {geoPosition && <meta name="geo.position" content={geoPosition} />}
    {geoPosition && <meta name="ICBM" content={geoPosition.replace(';', ', ')} />}

    {/* Theme color */}
    {themeColor && <meta name="theme-color" content={themeColor} />}

    {/* Open Graph */}
    {ogType && <meta property="og:type" content={ogType} />}
    {ogSiteName && <meta property="og:site_name" content={ogSiteName} />}
    {ogLocale && <meta property="og:locale" content={ogLocale} />}
    {ogTitle && <meta property="og:title" content={ogTitle} />}
    {ogDescription && <meta property="og:description" content={ogDescription} />}
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
    {ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}

    {/* Twitter Card */}
    {twitterCard && <meta name="twitter:card" content={twitterCard} />}
    {twitterTitle && <meta name="twitter:title" content={twitterTitle} />}
    {twitterDescription && <meta name="twitter:description" content={twitterDescription} />}
    {twitterImage && <meta name="twitter:image" content={twitterImage} />}
    {twitterSite && <meta name="twitter:site" content={twitterSite} />}

    {/* Performance hints */}
    {preconnect?.map(url => <link rel="preconnect" href={url} />)}
    {dnsPrefetch?.map(url => <link rel="dns-prefetch" href={url} />)}
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    {/* No padding here — sections paint edge-to-edge so a dark or image hero
        can extend its background behind the floating nav pill. Each section
        that sits at the top or bottom of the page is responsible for leaving
        its own clearance for the floating bars. */}
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
