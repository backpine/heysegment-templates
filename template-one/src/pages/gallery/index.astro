---
/**
 * Gallery page, visual portfolio of completed projects.
 *
 * Composition mirrors the home / services / service-area page style.
 * Photo-first, conversion-tail.
 *
 *   1. Inline page header        , dark navy + pill H1 + dual CTA + breadcrumbs INSIDE
 *   2. GalleryGrid               , Pinterest-style mixed-aspect tiles with hover overlay
 *   3. TestimonialsTeal          , reused (social proof for visitors who scrolled the gallery)
 *   4. WhatMakesUsDifferent      , reused (3 differentiators)
 *   5. FinalCTA                  , reused with dual CTA enabled
 *
 * Intentionally tight composition, gallery is the focus, the rest is
 * conversion tail.
 */
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/global/Breadcrumbs.astro";
import GalleryGrid from "@/components/gallery/GalleryGrid.astro";
import TestimonialsTeal from "@/components/home/TestimonialsTeal.astro";
import WhatMakesUsDifferent from "@/components/home/WhatMakesUsDifferent.astro";
import FinalCTA from "@/components/global/FinalCTA.astro";
import { business } from "@/data/business";

const city = business.address?.city;
const state = business.address?.state;
const cityState = state ? `${city}, ${state}` : city ?? "Your Area";

const phoneHref = "tel:+1" + business.phone.replace(/\D/g, "");

const h1Pill = `Project Gallery in ${cityState}`;
---

<Layout
  title={`Project Gallery, ${business.name}`}
  description={`See completed work by ${business.name}, real projects across ${cityState} and surrounding areas. Hover any photo to see what we did.`}
>
  {/* 1. Inline page header, dark navy hero pattern with breadcrumbs
       INSIDE so the dark bg paints to the very top of the page. */}
  <section class="relative bg-text overflow-hidden isolate">

    {/* Background gradient placeholder. */}
    <div class="absolute inset-0 z-0 bg-gradient-to-br from-text via-text to-brand-deep">
      <div class="absolute bottom-3 right-3 z-30 max-w-[260px] text-right">
        <p class="font-body text-[10px] uppercase tracking-widest text-brand-fg/40">
          PAGE HEADER BACKGROUND
        </p>
        <p class="font-body text-[11px] text-brand-fg/40 mt-1 leading-snug">
          Wide hero photo, hero project / branded vehicle / crew at work
        </p>
      </div>
    </div>

    {/* Dark gradient overlay for readable copy. */}
    <div
      class="absolute inset-0 z-10 bg-gradient-to-r from-text/90 via-text/65 to-text/30"
      aria-hidden="true"
    ></div>

    {/* Breadcrumbs overlaid on the dark hero. */}
    <div class="relative z-20 pt-24 lg:pt-28">
      <Breadcrumbs trail={[{ label: "Gallery", href: "/gallery" }]} variant="overlay" />
    </div>

    {/* Content */}
    <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-10 pt-12 lg:pt-16 pb-20 lg:pb-28">
      <div class="max-w-3xl">

        {/* H1 pill, local-SEO pattern. */}
        <h1
          class="inline-block bg-brand text-brand-fg font-body font-bold text-xs sm:text-sm tracking-widest uppercase px-5 py-2.5 rounded-pill shadow-md mb-6"
          data-reveal
          data-reveal-from="up"
        >
          {h1Pill}
        </h1>

        {/* Big visual headline */}
        <p
          class="font-heading font-extrabold text-4xl sm:text-5xl lg:text-6xl text-brand-fg leading-[1.05] tracking-tight"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="100"
        >
          See the work, <span class="text-brand italic">in pixels.</span>
        </p>

        {/* Subtext */}
        <p
          class="font-body text-base lg:text-lg text-brand-fg/80 mt-6 max-w-2xl leading-relaxed"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="200"
        >
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Real projects, real homes, real results across {cityState}.
        </p>

        {/* Dual CTA */}
        <div
          class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-3 sm:gap-4 mt-10"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="300"
        >
          <a
            href={business.ctaHref}
            class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-deep text-brand-fg font-body font-bold text-base lg:text-lg px-8 py-4 rounded-pill shadow-lg transition-all hover:shadow-xl hover:scale-[1.02]"
          >
            {business.ctaLabel}
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href={phoneHref}
            class="inline-flex items-center justify-center gap-2 bg-transparent text-brand-fg ring-2 ring-brand-fg/70 font-body font-bold text-base lg:text-lg px-8 py-4 rounded-pill hover:bg-brand-fg hover:text-text transition-colors whitespace-nowrap"
          >
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd"/>
            </svg>
            Call {business.phone}
          </a>
        </div>

      </div>
    </div>
  </section>

  {/* 2. The gallery itself, photo-first masonry. */}
  <GalleryGrid />

  {/* 3. Reviews, social proof for visitors who just browsed the gallery.
         - topWaveBg="bg"      , GalleryGrid above is bg-bg, so the wave
                                 has to match (default would leave a
                                 white strip between bg-bg and the teal
                                 wave).
         - bottomWaveBg="surface" , the wave transitions cleanly into
                                 the bg-surface WhatMakesUsDifferent
                                 section below. */}
  <TestimonialsTeal topWaveBg="bg" bottomWaveBg="surface" />

  {/* 4. The 3 big differentiators. */}
  <WhatMakesUsDifferent />

  {/* 5. Final CTA, dual CTA enabled. */}
  <FinalCTA
    eyebrow={null}
    heading={`Like what you see?`}
    subtext="Free quote on your project. Honest pricing, no pressure."
    primaryCta={{ label: business.ctaLabel, href: business.ctaHref }}
    secondaryCta={{ label: `Call ${business.phone}`, href: phoneHref }}
  />
</Layout>
