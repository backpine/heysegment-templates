---
/**
 * ServiceAreaMap, wide visual section. Map (or stylized coverage area)
 * fills the left half; a teal CTA panel with copy + button sits on the
 * right; a service-vehicle photo placeholder partially overlaps both.
 *
 * Revive style: the truck "drives across" the visual seam between map
 * and panel. We approximate the layered effect with a positioned
 * placeholder.
 */
import { business } from "@/data/business";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Props {
  eyebrow?: string;
  heading?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const city = business.address?.city;

const {
  eyebrow = "Coverage Area",
  heading = `Top Quality. Right In ${city}.`,
  ctaLabel = business.ctaLabel,
  ctaHref = business.ctaHref,
} = Astro.props;
---

<section class="bg-bg py-12 lg:py-16">
  <div class="max-w-7xl mx-auto px-0 lg:px-10">

    <div class="relative grid lg:grid-cols-12 lg:gap-0 items-stretch overflow-hidden lg:rounded-2xl shadow-xl">

      <!-- LEFT: map placeholder -->
      <div class="lg:col-span-7 relative bg-brand-tint min-h-[360px] lg:min-h-[480px]">
        <!-- Map grid suggestion overlay -->
        <div
          class="absolute inset-0 opacity-40 pointer-events-none"
          aria-hidden="true"
          style="background-image: linear-gradient(0deg, rgba(8,145,178,.18) 1px, transparent 1px), linear-gradient(90deg, rgba(8,145,178,.18) 1px, transparent 1px); background-size: 40px 40px;"
        ></div>
        <!-- Pins -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-8 pointer-events-none" aria-hidden="true">
          <svg class="w-14 h-14 text-brand mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <p class="font-body text-xs font-bold uppercase tracking-widest text-brand">
            COVERAGE MAP
          </p>
          <p class="font-body text-xs text-text-soft mt-2 max-w-xs">
            Embed Google My Maps showing service-area coverage with pins on every city served.
          </p>
        </div>

        <!-- Decorative scattered city pins -->
        <span class="absolute top-[20%] left-[18%] w-3 h-3 bg-brand rounded-full ring-4 ring-bg" aria-hidden="true"></span>
        <span class="absolute top-[35%] left-[42%] w-3 h-3 bg-brand rounded-full ring-4 ring-bg" aria-hidden="true"></span>
        <span class="absolute top-[55%] left-[28%] w-3 h-3 bg-brand rounded-full ring-4 ring-bg" aria-hidden="true"></span>
        <span class="absolute top-[68%] left-[52%] w-3 h-3 bg-brand rounded-full ring-4 ring-bg" aria-hidden="true"></span>
        <span class="absolute top-[28%] left-[68%] w-3 h-3 bg-brand rounded-full ring-4 ring-bg" aria-hidden="true"></span>
        <span class="absolute top-[78%] left-[20%] w-3 h-3 bg-brand rounded-full ring-4 ring-bg" aria-hidden="true"></span>
      </div>

      <!-- RIGHT: teal CTA panel -->
      <div class="lg:col-span-5 bg-brand text-brand-fg p-8 lg:p-12 flex flex-col justify-center">
        {eyebrow && (
          <p class="font-body text-xs font-bold tracking-widest uppercase text-brand-fg/85 mb-3">
            {eyebrow}
          </p>
        )}
        <h2 class="font-heading font-extrabold text-2xl lg:text-3xl text-brand-fg leading-tight">
          {heading}
        </h2>
        <p class="font-body text-base text-brand-fg/85 mt-4 leading-relaxed">
          Serving {business.serviceAreas.length}+ cities across the region. If your address is in our zone, we can usually be there same-week.
        </p>
        <div class="mt-7">
          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 bg-brand-fg text-brand font-body font-bold text-sm tracking-widest uppercase px-7 py-3.5 rounded-pill shadow-lg hover:bg-brand-tint transition-colors"
          >
            {ctaLabel}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Floating vehicle photo, overlapping the seam -->
      <div class="hidden lg:block absolute bottom-6 left-[42%] -translate-x-1/2 w-72 z-30 ring-4 ring-bg rounded-xl overflow-hidden shadow-2xl">
        <ImagePlaceholder
          aspect="16/9"
          label="VEHICLE PHOTO"
          hint="Branded vehicle or service truck"
          bloomPosition="tl"
        />
      </div>

    </div>

  </div>
</section>
