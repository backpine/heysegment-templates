---
/**
 * Popular services, numbered editorial grid.
 *
 * Intentionally uncarded: each service is anchored only by a hairline top
 * border and a numbered label. The section reads like a well-set magazine
 * spread rather than a wall of identical tiles.
 */
import { business } from "@/data/business";

interface Service {
  name: string;
  description: string;
  slug?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  services?: Service[];
  viewAllHref?: string;
}

// In the Mirror Strategy, broad GBP categories (tier="category") get their
// own dedicated home-page section via CategoriesOverview. This section
// surfaces specific services and critical services, not the categories,
// which would duplicate content above.
const defaultServices = business.services.filter(
  (s) => !("tier" in s) || s.tier !== "category"
);

const {
  eyebrow = "Specific Services",
  heading = "What we do best.",
  subtext = "Specific services within our main categories. If you don't see what you need, give us a call, chances are we do that too.",
  services = defaultServices,
  viewAllHref = "/services",
} = Astro.props;

// "Learn more" links only render for services that actually have a detail
// page. Keeps the home page from pointing visitors at 404s.
const detailSlugs = new Set(business.serviceDetails.map((d) => d.slug));
---

<section id="services" class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="max-w-2xl mb-14 lg:mb-20">
      {eyebrow && (
        <div class="inline-flex items-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
        </div>
      )}
      <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">{heading}</h2>
      {subtext && (
        <p class="font-body text-base lg:text-lg text-text-soft mt-4 leading-relaxed">
          {subtext}
        </p>
      )}
    </div>

    <!-- Service grid, no cards; each item anchored by a brand hairline -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10" role="list">
      {services.map((service, i) => (
        <li class="group relative pt-6 border-t-2 border-brand/25">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-heading text-xl text-brand leading-none">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft">
              Service
            </span>
          </div>

          <h3 class="font-heading text-xl text-text leading-snug">
            {service.name}
          </h3>

          <p class="font-body text-sm text-text-soft mt-3 leading-relaxed">
            {service.description}
          </p>

          {service.slug && detailSlugs.has(service.slug) && (
            <a
              href={`/services/${service.slug}`}
              class="inline-flex items-center gap-1.5 mt-5 font-body text-sm font-semibold text-brand hover:gap-2.5 transition-all duration-150"
              aria-label={`Learn more about ${service.name}`}
            >
              Learn more
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- View all services -->
    <div class="mt-16 pt-8 border-t border-border flex items-center justify-between gap-4 flex-wrap">
      <p class="font-body text-sm text-text-soft">
        Don't see what you're looking for? We handle custom work too.
      </p>
      <a
        href={viewAllHref}
        class="inline-flex items-center gap-2 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
      >
        View all services
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
