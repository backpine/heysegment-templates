---
/**
 * CategoriesOverview, the central Mirror Strategy section.
 *
 * The home page should mirror the structure of the business's Google
 * Business Profile: one H2 section per GBP category, each with a 50–100
 * word body block and an internal link to the dedicated category page.
 *
 * Google's local algorithm rewards exact alignment between site structure
 * and GBP category structure, this section is what creates that
 * alignment. It is the single most important on-page SEO move in the
 * template.
 *
 * Renders services with `tier === "category"` from business.ts. Each
 * category alternates left/right alignment for editorial rhythm. Each
 * section ends with an arrow link to the dedicated /services/[slug] page.
 */
import { business } from "@/data/business";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Category {
  name: string;
  slug: string;
  body?: string;
  description?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  categories?: Category[];
}

const {
  eyebrow = "What We Do",
  heading = "Complete services for your whole home.",
  subtext = "Each category below is a service where we have proven experience. Click any to see more detail.",
  categories = business.services
    .filter((s) => s.tier === "category")
    .map((s) => ({
      name: s.name,
      slug: s.slug,
      body: s.body,
      description: s.description,
    })),
} = Astro.props;

// Use city in headings if available, sharper local SEO signal.
const primaryCity = business.address?.city;
---

<section id="categories" class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="max-w-2xl mb-16 lg:mb-24">
      {eyebrow && (
        <div class="inline-flex items-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
        </div>
      )}
      <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
        {heading}
      </h2>
      {subtext && (
        <p class="font-body text-base lg:text-lg text-text-soft mt-4 leading-relaxed">
          {subtext}
        </p>
      )}
    </div>

    <!-- Category sections, alternating left/right, hairline dividers -->
    <div class="space-y-16 lg:space-y-24">
      {categories.map((category, i) => {
        const isReversed = i % 2 === 1;
        const number = String(i + 1).padStart(2, "0");
        const text = category.body ?? category.description ?? "";
        const headingWithCity = primaryCity
          ? `${category.name} in ${primaryCity}`
          : category.name;

        return (
          <article class="grid lg:grid-cols-12 gap-10 lg:gap-14 pt-10 border-t-2 border-brand/25 first:border-t-0 first:pt-0">

            <!-- Copy column -->
            <div class={`lg:col-span-7 ${isReversed ? "lg:order-2" : "lg:order-1"}`}>
              <div class="flex items-baseline gap-3 mb-4">
                <span class="font-heading text-xl text-brand leading-none tabular-nums">
                  {number}
                </span>
                <span class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft">
                  Category
                </span>
              </div>

              <h3 class="font-heading text-2xl lg:text-3xl text-text leading-tight">
                {headingWithCity}
              </h3>

              <p class="font-body text-base lg:text-lg text-text-soft mt-5 leading-relaxed max-w-xl">
                {text}
              </p>

              <a
                href={`/services/${category.slug}`}
                class="inline-flex items-center gap-2 mt-7 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
                aria-label={`Learn more about ${category.name}`}
              >
                Explore {category.name}
                <svg
                  class="w-4 h-4 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                  />
                </svg>
              </a>
            </div>

            <!-- Image column -->
            <div class={`lg:col-span-5 ${isReversed ? "lg:order-1" : "lg:order-2"}`}>
              <ImagePlaceholder
                aspect="4/3"
                label="SERVICE PHOTO"
                hint="Photo of this service in action"
                bloomPosition={isReversed ? "tl" : "tr"}
              />
            </div>

          </article>
        );
      })}
    </div>

    <!-- View all services -->
    <div class="mt-20 pt-8 border-t border-border flex items-center justify-between gap-4 flex-wrap">
      <p class="font-body text-sm text-text-soft">
        Looking for something specific? See every service we offer.
      </p>
      <a
        href="/services"
        class="inline-flex items-center gap-2 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
      >
        View all services
        <svg
          class="w-4 h-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
          />
        </svg>
      </a>
    </div>

  </div>
</section>
