---
/**
 * TrustStrip, slim row of credibility markers shown immediately below
 * the hero. Universal pattern across every premium home service site:
 * Licensed · Insured · Since [year] · 5.0 ★ Google · BBB.
 *
 * Renders the `business.certifications` array. Falls back gracefully if
 * empty. Optional identity badge surfaces as a leading pill when present.
 */
import { business } from "@/data/business";

interface Item {
  label: string;
}

interface Props {
  items?: Item[];
  identityBadge?: { short: string; long: string } | null;
}

const {
  items = business.certifications ?? [],
  identityBadge = business.identityBadge ?? null,
} = Astro.props;

const showSection = items.length > 0 || identityBadge;
---

{showSection && (
  <section class="bg-surface border-y border-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-5 lg:py-6">
      <ul class="flex flex-wrap items-center justify-center lg:justify-between gap-x-8 gap-y-3" role="list">

        {identityBadge && (
          <li class="inline-flex items-center gap-2 bg-brand-tint text-brand font-body font-semibold text-xs tracking-wide uppercase px-3 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" clip-rule="evenodd"/>
            </svg>
            {identityBadge.short}
          </li>
        )}

        {items.map((item) => (
          <li class="inline-flex items-center gap-2 font-body text-sm text-text-soft">
            <svg class="w-4 h-4 text-brand shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
            </svg>
            <span class="font-medium text-text">{item.label}</span>
          </li>
        ))}

      </ul>
    </div>
  </section>
)}
