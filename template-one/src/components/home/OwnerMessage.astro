---
/**
 * OwnerMessage, first-person founder block. The single biggest trust
 * lever on a local service site. Photo on the left, message on the
 * right, signature line below. Editorial layout matching template-one's
 * other two-up sections.
 *
 * Renders `business.owner`. Falls back to nothing if not present so
 * sites without an owner-fronted brand don't get a hollow section.
 */
import { business } from "@/data/business";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Owner {
  name: string;
  role: string;
  initials?: string;
  message: string;
  signaturePhoto?: string;
}

interface Props {
  eyebrow?: string;
  owner?: Owner | null;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow = "A Note from the Owner",
  owner = business.owner ?? null,
  ctaHref = business.ctaHref,
  ctaLabel = `Talk to ${business.owner?.name?.split(" ")[0] ?? "us"}`,
} = Astro.props;
---

{owner && (
  <section class="bg-bg py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

        <!-- Photo column -->
        <div class="lg:col-span-5">
          <ImagePlaceholder
            aspect="4/5"
            label={`${owner.name}, ${owner.role}`}
            hint="Owner portrait"
            bloomPosition="bl"
          />
        </div>

        <!-- Message column -->
        <div class="lg:col-span-7">
          {eyebrow && (
            <div class="inline-flex items-center gap-2.5 mb-5">
              <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
              <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
                {eyebrow}
              </span>
            </div>
          )}

          <blockquote class="font-heading text-2xl lg:text-3xl text-text leading-snug">
            <span class="text-brand text-4xl leading-none align-top mr-1" aria-hidden="true">&ldquo;</span>
            {owner.message}
            <span class="text-brand text-4xl leading-none align-top ml-0.5" aria-hidden="true">&rdquo;</span>
          </blockquote>

          <!-- Signature line -->
          <div class="mt-8 flex items-center gap-4 pt-6 border-t border-border">
            {owner.initials && (
              <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand text-brand-fg font-heading text-lg shrink-0">
                {owner.initials}
              </span>
            )}
            <div>
              <p class="font-body font-semibold text-text">{owner.name}</p>
              <p class="font-body text-sm text-text-soft">{owner.role}</p>
            </div>
          </div>

          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 mt-7 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
          >
            {ctaLabel}
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>
)}
