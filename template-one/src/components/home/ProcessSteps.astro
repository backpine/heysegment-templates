---
/**
 * ProcessSteps, three-step "how we work" section.
 *
 * Each step gets:
 *   - A teal-tint icon disc with a universal home-service icon
 *     (quote, calendar, check) that runs a continuous subtle
 *     "alive" animation, plus a stronger animation on hover.
 *   - A numbered badge (01 / 02 / 03) in the top-right corner of
 *     the icon disc.
 *   - Title + description (centered).
 *   - A dashed teal connector line running across all three discs
 *     on lg+ to suggest forward motion.
 *
 * The icon-specific keyframes simulate "thumbing through":
 *   quote     → subtle paper-flip rocking (page turn motion)
 *   calendar  → small bounce (calendar page tear)
 *   check     → gentle pulse (confirmation glow)
 *
 * Reads `business.processSteps` (3 items by convention). Icons can
 * be overridden per-step via the `icon` field.
 */
import { business } from "@/data/business";

interface Step {
  title: string;
  description: string;
  icon?: "quote" | "calendar" | "check" | "phone" | "wrench" | "shield";
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  steps?: Step[];
  ctaHref?: string;
  ctaLabel?: string;
}

// Default icon mapping for the standard 3-step pattern.
const defaultSteps: Step[] = (business.processSteps ?? []).map((s, i) => ({
  ...s,
  icon: (s as { icon?: Step["icon"] }).icon ?? (["quote", "calendar", "check"][i] as Step["icon"]),
}));

const {
  eyebrow = "Working With Us Is Easy As 1-2-3",
  heading = "Our Simple 3-Step Process",
  subtext = "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt.",
  steps = defaultSteps,
  ctaHref = business.ctaHref,
  ctaLabel = business.ctaLabel,
} = Astro.props;

// Universal home-service icon registry.
const iconPath: Record<NonNullable<Step["icon"]>, string> = {
  quote:    "M3 5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2H5a2 2 0 01-2-2V5zM8 11h8M8 15h5",
  calendar: "M8 7V3m8 4V3M3 11h18M5 5h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z",
  check:    "M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  phone:    "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
  wrench:   "M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z",
  shield:   "M9 12l2 2 4-4M12 2L4 6v6c0 5.5 3.84 10.74 8 12 4.16-1.26 8-6.5 8-12V6l-8-4z",
};
---

<section class="bg-surface py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-16 lg:mb-20">
      {eyebrow && (
        <p
          class="font-body text-sm font-bold tracking-widest uppercase text-brand mb-4"
          data-reveal
          data-reveal-from="up"
        >
          {eyebrow}
        </p>
      )}
      <h2
        class="font-heading font-extrabold text-4xl lg:text-5xl text-text leading-[1.1]"
        data-reveal
        data-reveal-from="up"
        data-reveal-delay="100"
      >
        {heading}
      </h2>
      {subtext && (
        <p
          class="font-body text-base lg:text-lg text-text-soft mt-4 leading-relaxed"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="200"
        >
          {subtext}
        </p>
      )}
    </div>

    <!-- Steps grid (centered, all viewports) -->
    <div class="relative">
      <!-- Dashed connector line on lg+ -->
      <svg
        class="hidden lg:block absolute left-[12%] right-[12%] top-12 h-2 text-brand/30 pointer-events-none"
        preserveAspectRatio="none"
        viewBox="0 0 100 1"
        aria-hidden="true"
      >
        <line x1="0" y1="0.5" x2="100" y2="0.5" stroke="currentColor" stroke-width="0.4" stroke-dasharray="0.6 0.8" />
      </svg>

      <ol class="grid grid-cols-1 lg:grid-cols-3 gap-y-14 lg:gap-x-12 relative" role="list">
        {steps.map((step, i) => (
          <li
            class="text-center group"
            data-reveal
            data-reveal-from="up"
            data-reveal-delay={String(i * 150) as "0" | "100" | "200" | "300" | "500" | "700"}
          >

            <!-- Icon disc (centered) -->
            <div class="flex justify-center mb-6">
              <span
                class="step-icon relative z-10 inline-flex items-center justify-center w-24 h-24 rounded-full bg-brand-tint ring-8 ring-surface text-brand transition-transform duration-500 group-hover:scale-110"
                data-step-icon={step.icon ?? "check"}
              >
                <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={iconPath[step.icon ?? "check"]} />
                </svg>
                <!-- Step number badge -->
                <span class="absolute -top-2 -right-2 inline-flex items-center justify-center w-9 h-9 rounded-full bg-brand text-brand-fg font-heading font-extrabold text-sm tabular-nums shadow-md ring-4 ring-surface">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </span>
            </div>

            <h3 class="font-heading font-extrabold text-xl lg:text-2xl text-text leading-snug">
              {step.title}
            </h3>
            <p class="font-body text-base text-text-soft mt-3 leading-relaxed max-w-sm mx-auto">
              {step.description}
            </p>
          </li>
        ))}
      </ol>
    </div>

    <!-- Closing CTA -->
    <div class="mt-16 text-center" data-reveal data-reveal-from="up">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 bg-brand hover:bg-brand-deep text-brand-fg font-body font-bold text-base px-8 py-4 rounded-pill shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all"
      >
        {ctaLabel}
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ────────────────────────────────────────────────────────────────────
     Step icon "alive" animations.
     Each icon plays its own continuous loop animation that hints at the
     action it represents:
       quote    → rocks slightly side-to-side like flipping through pages
       calendar → small bounce like tearing off a calendar page
       check    → gentle pulse like a confirmation glow
     Hover applies a stronger scale lift (handled by group-hover above);
     these keyframes keep the icons "breathing" even when no one is
     hovering, which makes the section feel alive on Revive-style sites.
  ──────────────────────────────────────────────────────────────────── */
  .step-icon[data-step-icon="quote"] svg {
    animation: step-flip 3.5s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    transform-origin: 75% 50%;
  }
  @keyframes step-flip {
    0%, 60%, 100% { transform: rotateY(0deg); }
    30%           { transform: rotateY(-22deg); }
  }

  .step-icon[data-step-icon="calendar"] svg {
    animation: step-bounce 2.8s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    transform-origin: center;
  }
  @keyframes step-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30%           { transform: translateY(-6px); }
  }

  .step-icon[data-step-icon="check"] svg {
    animation: step-pulse 2.4s ease-in-out infinite;
  }
  @keyframes step-pulse {
    0%, 100% { transform: scale(1);    opacity: 1;    }
    50%      { transform: scale(1.12); opacity: 0.85; }
  }

  /* Subtle disc-level breathing pulse, plays on every disc regardless
     of icon type. Layers under the icon-specific animation. */
  .step-icon::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    border: 2px solid currentColor;
    opacity: 0;
    animation: step-ring 2.6s ease-out infinite;
    pointer-events: none;
  }
  @keyframes step-ring {
    0%   { transform: scale(0.92); opacity: 0;    }
    50%  {                          opacity: 0.35; }
    100% { transform: scale(1.18); opacity: 0;    }
  }

  /* Stagger the ring + icon timings per disc so all three don't fire in
     unison; they should feel rhythmic, not robotic. */
  ol > li:nth-child(2) .step-icon svg { animation-delay: 0.3s; }
  ol > li:nth-child(3) .step-icon svg { animation-delay: 0.6s; }
  ol > li:nth-child(2) .step-icon::after { animation-delay: 0.4s; }
  ol > li:nth-child(3) .step-icon::after { animation-delay: 0.8s; }

  @media (prefers-reduced-motion: reduce) {
    .step-icon svg,
    .step-icon::after {
      animation: none;
    }
  }
</style>
