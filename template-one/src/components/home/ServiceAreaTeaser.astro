---
/**
 * ServiceAreaTeaser, home-page section that surfaces service-area
 * cities as a tag grid + link to the dedicated service-area pages.
 * Massive local-SEO lever: cities mentioned on the home page reinforce
 * topical-geographic relevance, and the internal links pass authority
 * to the city pages where ranking happens.
 *
 * Renders all `business.serviceAreas` as tags. Cities that have a
 * dedicated detail page (entries in `business.locations`) get linked;
 * the rest render as plain text tags.
 */
import { business } from "@/data/business";

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow = "Where We Work",
  heading = "Serving the area we live in.",
  subtext = "Our crew lives here, works here, and stands behind the work in every neighborhood we serve. If your city's on this list, we can be there fast.",
  ctaHref = "/service-area",
  ctaLabel = "See full service area",
} = Astro.props;

// Map city names to detail-page slugs where available
const citySlugMap = new Map(
  business.locations.map((loc) => [loc.name, loc.slug])
);

const cities = business.serviceAreas.map((name) => ({
  name,
  slug: citySlugMap.get(name) ?? null,
}));
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT: heading -->
      <div class="lg:col-span-5">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}
        <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
          {heading}
        </h2>
        <p class="font-body text-base lg:text-lg text-text-soft mt-5 leading-relaxed max-w-md">
          {subtext}
        </p>
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 mt-7 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
        >
          {ctaLabel}
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- RIGHT: cities tag grid -->
      <div class="lg:col-span-7">
        <ul class="flex flex-wrap gap-2.5" role="list">
          {cities.map((city) => (
            city.slug ? (
              <li>
                <a
                  href={`/service-area/${city.slug}`}
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-surface border border-border font-body text-sm font-medium text-text hover:bg-brand hover:text-brand-fg hover:border-brand transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                >
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {city.name}
                </a>
              </li>
            ) : (
              <li class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-surface border border-border font-body text-sm font-medium text-text-soft">
                <svg class="w-3.5 h-3.5 shrink-0 text-brand/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {city.name}
              </li>
            )
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
