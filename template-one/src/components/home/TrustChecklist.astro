---
/**
 * TrustChecklist, split section.
 *
 * Left column: tall house photo placeholder + circular technician
 *   portrait overlay.
 * Right column: short heading + vertical stack of brand-color checklist
 *   pills (8 items by default from business.whyChooseUs.features).
 *
 * Reads from business.whyChooseUs.features. Each pill animates in with
 * a staggered slide-from-right reveal as the user scrolls into view.
 */
import { business } from "@/data/business";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Item {
  title: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  items?: Item[];
}

const {
  eyebrow = business.whyChooseUs?.eyebrow ?? "Why Trust Us?",
  heading = `Why Trust ${business.name.split(" ")[0]}?`,
  items = business.whyChooseUs?.features ?? [],
} = Astro.props;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- LEFT: stacked photos -->
      <div
        class="lg:col-span-5 relative"
        data-reveal
        data-reveal-from="left"
      >
        <ImagePlaceholder
          aspect="4/5"
          label="FEATURED PHOTO"
          hint="Finished work or branded shot"
          bloomPosition="tl"
        />
        <!-- Floating circular portrait overlay -->
        <div class="absolute -bottom-8 -left-2 lg:-left-8 w-1/2 lg:w-2/5 z-20">
          <div class="aspect-square rounded-full overflow-hidden ring-8 ring-bg shadow-xl bg-brand-tint relative">
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
              <span class="font-body text-[10px] font-bold tracking-widest uppercase text-brand">
                PORTRAIT
              </span>
              <span class="font-body text-[10px] text-text-soft mt-1 max-w-[14ch] leading-tight">
                Owner or technician
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: heading + checklist -->
      <div class="lg:col-span-7">
        {eyebrow && (
          <div
            class="inline-flex items-center gap-2.5 mb-3"
            data-reveal
            data-reveal-from="right"
          >
            <span class="block w-1 h-6 bg-brand rounded-full" aria-hidden="true"></span>
            <span class="font-body text-sm font-bold tracking-wider uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h2
          class="font-heading font-extrabold text-4xl lg:text-5xl text-text leading-[1.1] mb-8"
          data-reveal
          data-reveal-from="right"
          data-reveal-delay="100"
        >
          {heading}
        </h2>

        <ul class="space-y-3" role="list">
          {items.map((item, i) => (
            <li
              class="flex items-stretch overflow-hidden rounded-pill shadow-sm"
              data-reveal
              data-reveal-from="right"
              data-reveal-delay={String(Math.min(i * 75, 700)) as "0" | "100" | "200" | "300" | "500" | "700"}
            >
              <span class="bg-brand-deep text-brand-fg shrink-0 w-12 flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="bg-brand text-brand-fg flex-1 font-body font-semibold text-sm lg:text-base px-5 py-3">
                {item.title}
              </span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
