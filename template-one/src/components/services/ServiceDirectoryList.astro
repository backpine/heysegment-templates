---
/**
 * ServiceDirectoryList, full directory of every service rendered as a
 * horizontal list of detail cards on a dark navy background.
 *
 * Visual pattern:
 *   - Dark navy section background (continues from the page header so the
 *     dark color flows through without a white seam between sections).
 *   - Each service is a horizontal row card:
 *       LEFT  : large image placeholder with service-icon badge
 *       RIGHT : numbered eyebrow (01/02/03…) + service name + longer
 *               description + sub-services chip list + Learn More CTA
 *   - Cards stack vertically going down the page so any number of services
 *     can be added to the data layer without breaking the layout.
 *   - Bottom wave divider transitions text → brand so the section flows
 *     directly into the next teal section with no light gap.
 *
 * No hover-overlay animation, this is a content-rich directory, not the
 * compact home-page teaser grid.
 *
 * Reads `business.services` (categories only, sub-services rendered as chips
 * on their parent's card).
 */
import { business } from "@/data/business";
import WaveDivider from "@/components/global/WaveDivider.astro";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface SubService {
  name: string;
  slug: string;
}

interface ServiceRow {
  name: string;
  slug: string;
  icon?: string;
  description: string;
  body?: string;
  subServices: SubService[];
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  /** Whether the next section is the brand-color teal (controls the bottom wave). */
  bottomTransition?: "brand" | "bg" | "none";
}

// Build the directory rows. Categories first, with their sub-services
// attached as chips so the list reads like a real catalog.
const categories = business.services.filter((s) => s.tier === "category");
const allServices = business.services;
const detailSlugs = new Set(business.serviceDetails.map((d) => d.slug));

const rows: ServiceRow[] = categories.map((cat) => {
  const subServices = allServices
    .filter((s) => "parentSlug" in s && s.parentSlug === cat.slug)
    .map((s) => ({ name: s.name, slug: s.slug }));
  return {
    name: cat.name,
    slug: cat.slug,
    icon: (cat as { icon?: string }).icon,
    description: cat.description,
    body: (cat as { body?: string }).body,
    subServices,
  };
});

const {
  eyebrow = "Our Lineup",
  heading = "Browse Every Service",
  subtext = "Tap any service to see what's included, common questions, and pricing notes. Don't see what you need? Give us a call.",
  bottomTransition = "brand",
} = Astro.props;

const iconFor = (key: string | undefined) => {
  switch (key) {
    case "spray":
      return "M12 3v3m0 12v3M5.636 5.636l2.122 2.122m8.485 8.485l2.122 2.122M3 12h3m12 0h3M5.636 18.364l2.122-2.122m8.485-8.485l2.122-2.122M9 12a3 3 0 116 0 3 3 0 01-6 0z";
    case "house":
      return "M3 12l9-9 9 9M5 10v10a1 1 0 001 1h3v-6h6v6h3a1 1 0 001-1V10";
    case "roof":
      return "M2 12L12 4l10 8M5 11v9h14v-9";
    case "gutter":
      return "M3 7h18M5 7v6a4 4 0 004 4h6a4 4 0 004-4V7M9 17v4M15 17v4";
    case "wrench":
      return "M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z";
    case "pin":
      return "M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z";
    default:
      return "M5 13l4 4L19 7";
  }
};

const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="bg-text text-brand-fg relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-16 lg:pt-20 pb-20 lg:pb-28">

    <!-- Section header -->
    <div class="max-w-3xl mb-12 lg:mb-16">
      {eyebrow && (
        <p
          class="font-body text-sm font-bold tracking-widest uppercase text-brand mb-4"
          data-reveal
          data-reveal-from="up"
        >
          {eyebrow}
        </p>
      )}
      <h2
        class="font-heading font-extrabold text-4xl lg:text-5xl text-brand-fg leading-[1.1]"
        data-reveal
        data-reveal-from="up"
        data-reveal-delay="100"
      >
        {heading}
      </h2>
      {subtext && (
        <p
          class="font-body text-base lg:text-lg text-brand-fg/70 mt-5 leading-relaxed max-w-2xl"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="200"
        >
          {subtext}
        </p>
      )}
    </div>

    <!-- List of service rows -->
    <ul class="space-y-6 lg:space-y-8" role="list">
      {rows.map((row, i) => {
        const hasDetailPage = detailSlugs.has(row.slug);
        const href = hasDetailPage ? `/services/${row.slug}` : "/contact";

        return (
          <li
            class="group relative"
            data-reveal
            data-reveal-from="up"
            data-reveal-delay={String(Math.min(i * 100, 300)) as "0" | "100" | "200" | "300"}
          >
            <article class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-center bg-brand-fg/[0.04] hover:bg-brand-fg/[0.07] transition-colors rounded-2xl p-5 lg:p-7 ring-1 ring-brand-fg/10">

              <!-- LEFT: image placeholder with floating icon badge -->
              <div class="lg:col-span-5 relative">
                <ImagePlaceholder
                  aspect="16/9"
                  label={row.name.toUpperCase()}
                  hint="Photo of this service"
                  bloomPosition="tl"
                />
                <!-- Service-number badge, top-left of image -->
                <span
                  class="absolute top-3 left-3 inline-flex items-center justify-center font-heading font-extrabold text-xs tracking-widest text-brand-fg bg-brand px-3 py-1.5 rounded-pill shadow-md"
                  aria-hidden="true"
                >
                  {pad(i)}
                </span>
                <!-- Service-icon disc, bottom-right of image -->
                <span
                  class="absolute bottom-3 right-3 inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand text-brand-fg shadow-lg ring-4 ring-text"
                >
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconFor(row.icon)} />
                  </svg>
                </span>
              </div>

              <!-- RIGHT: name, copy, sub-service chips, CTA -->
              <div class="lg:col-span-7">
                <p class="font-body text-xs font-bold tracking-widest uppercase text-brand mb-2">
                  Service {pad(i)}
                </p>
                <h3 class="font-heading font-extrabold text-2xl lg:text-3xl text-brand-fg leading-tight">
                  {row.name}
                </h3>
                <p class="font-body text-sm lg:text-base text-brand-fg/75 mt-3 leading-relaxed">
                  {row.body ?? row.description}
                </p>

                {row.subServices.length > 0 && (
                  <div class="mt-5">
                    <p class="font-body text-[11px] font-bold tracking-widest uppercase text-brand-fg/50 mb-2">
                      Includes
                    </p>
                    <ul class="flex flex-wrap gap-2" role="list">
                      {row.subServices.map((sub) => (
                        <li>
                          <span class="inline-flex items-center gap-1.5 bg-brand-fg/10 text-brand-fg/90 font-body text-xs font-semibold px-3 py-1.5 rounded-pill ring-1 ring-brand-fg/15">
                            <svg class="w-3 h-3 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                            {sub.name}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class="mt-6 flex flex-wrap items-center gap-3">
                  <a
                    href={href}
                    class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-deep text-brand-fg font-body font-bold text-sm px-6 py-3 rounded-pill shadow-md hover:shadow-lg hover:scale-[1.02] transition-all"
                  >
                    {hasDetailPage ? "Learn More" : "Get a Quote"}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                  <a
                    href={business.ctaHref}
                    class="inline-flex items-center gap-1.5 font-body text-sm font-semibold text-brand-fg/80 hover:text-brand-fg transition-colors"
                  >
                    Get a Free Quote
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>

            </article>
          </li>
        );
      })}
    </ul>

  </div>

  {bottomTransition === "brand" && (
    <WaveDivider direction="down" fill="brand" bgFrom="text" />
  )}
  {bottomTransition === "bg" && (
    <WaveDivider direction="down" fill="bg" bgFrom="text" />
  )}
</section>
