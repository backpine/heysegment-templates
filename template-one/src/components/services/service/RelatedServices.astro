---
/**
 * Related services — 3-col editorial grid of other services we offer.
 *
 * Distinct from ServicesList (2-col, numbered): this is a tighter 3-col
 * grid of short entries, anchored by a hairline top border. Each service
 * title links to its detail page when one exists, otherwise renders as
 * plain text. No cards.
 */
import { business } from "@/data/business";

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  currentSlug?: string;
  overviewHref?: string;
  overviewLabel?: string;
}

const {
  eyebrow = "Other Services",
  heading = "Quid aliud facimus.",
  subtext =
    "Lorem ipsum dolor sit amet — eadem cura, eadem grex, omnia a prima voce ad ultimam inspectionem.",
  currentSlug,
  overviewHref = "/services",
  overviewLabel = "View all services",
} = Astro.props;

const detailSlugs = new Set(business.serviceDetails.map((d) => d.slug));
const others = business.services.filter((s) => s.slug !== currentSlug);
---

<section class="bg-surface py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="max-w-2xl mb-14 lg:mb-16">
      {eyebrow && (
        <div class="inline-flex items-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
        </div>
      )}
      <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">{heading}</h2>
      {subtext && (
        <p class="font-body text-base text-text-soft mt-4 leading-relaxed">
          {subtext}
        </p>
      )}
    </div>

    <!-- 3-col grid of short entries, hairline-anchored -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10" role="list">
      {others.map((service) => {
        const hasPage = detailSlugs.has(service.slug);
        return (
          <li class="group pt-5 border-t border-brand/25">
            <h3 class="font-heading text-xl text-text leading-snug">
              {hasPage ? (
                <a
                  href={`/services/${service.slug}`}
                  class="hover:text-brand transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand rounded-sm"
                >
                  {service.name}
                </a>
              ) : (
                service.name
              )}
            </h3>
            <p class="font-body text-sm text-text-soft mt-2 leading-relaxed line-clamp-3">
              {service.description}
            </p>
            {hasPage && (
              <a
                href={`/services/${service.slug}`}
                class="inline-flex items-center gap-1.5 mt-4 font-body text-sm font-semibold text-brand hover:gap-2.5 transition-all duration-150"
                aria-label={`Learn more about ${service.name}`}
              >
                Learn more
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            )}
          </li>
        );
      })}
    </ul>

    <!-- Overview CTA -->
    <div class="mt-14 pt-8 border-t border-border text-center">
      <a
        href={overviewHref}
        class="inline-flex items-center gap-2 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
      >
        {overviewLabel}
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
