---
/**
 * WhenYouNeedService, text-heavy editorial section that walks through
 * the situations that should prompt the customer to book this service.
 *
 * Visual rhythm matches the rest of the page:
 *   - Centered eyebrow + heading + italic-accent lead paragraph (mirrors
 *     home WelcomeIntro and FAQ section header treatment).
 *   - Vertical list of scenario rows with hairline dividers between
 *     them (mirrors the home FAQ list pattern, no flashy cards, the
 *     layout itself stays out of the way and lets the prose carry the
 *     section).
 *   - Each scenario row has a small brand-tint icon disc on the left
 *     (mirrors ProcessSteps' icon-disc style, sized down so it feels
 *     like an editorial bullet rather than a hero element).
 *   - Closing centered CTA pair so the section converts.
 *
 * The narrow max-width (max-w-4xl) on the content column is deliberate.
 * Long-form copy reads better at a controlled measure, and the narrower
 * column visually distinguishes this section from the wide
 * WhatsIncluded / ServiceBenefits split-grid sections around it.
 */
import { business } from "@/data/business";

interface Scenario {
  title: string;
  description: string;
  icon?: "shield" | "wrench" | "check" | "calendar" | "phone" | "quote";
}

interface Props {
  eyebrow?: string;
  serviceName: string;
  heading?: string;
  /** Italic-accent lead sentence shown beneath the heading. */
  accent?: string;
  /** Body paragraph below the lead. */
  lead?: string;
  scenarios: Scenario[];
  primaryCta?: { label: string; href: string };
}

const phoneHref = "tel:+1" + business.phone.replace(/\D/g, "");

const {
  eyebrow = "When You Need It",
  serviceName,
  heading,
  accent,
  lead,
  scenarios,
  primaryCta = { label: business.ctaLabel, href: business.ctaHref },
} = Astro.props;

const resolvedHeading = heading ?? `When do you need ${serviceName}?`;
const resolvedAccent =
  accent ?? `If any of this sounds familiar, it's time.`;

// Universal home-service icon registry, matches ProcessSteps so the
// visual vocabulary stays consistent across the site.
const iconPath: Record<NonNullable<Scenario["icon"]>, string> = {
  quote: "M3 5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2H5a2 2 0 01-2-2V5zM8 11h8M8 15h5",
  calendar: "M8 7V3m8 4V3M3 11h18M5 5h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z",
  check: "M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  phone: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
  wrench: "M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z",
  shield: "M9 12l2 2 4-4M12 2L4 6v6c0 5.5 3.84 10.74 8 12 4.16-1.26 8-6.5 8-12V6l-8-4z",
};

const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="bg-surface py-20 lg:py-28">
  <div class="max-w-4xl mx-auto px-6 lg:px-10">

    <!-- Centered editorial header -->
    <div class="text-center mb-14 lg:mb-16">
      {eyebrow && (
        <div
          class="inline-flex items-center justify-center gap-2.5 mb-4"
          data-reveal
          data-reveal-from="up"
        >
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-bold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
        </div>
      )}

      <h2
        class="font-heading font-extrabold text-3xl lg:text-4xl text-text leading-[1.15]"
        data-reveal
        data-reveal-from="up"
        data-reveal-delay="100"
      >
        {resolvedHeading}
      </h2>

      {resolvedAccent && (
        <p
          class="font-heading font-bold italic text-xl lg:text-2xl text-brand mt-4 leading-snug"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="200"
        >
          {resolvedAccent}
        </p>
      )}

      {lead && (
        <p
          class="font-body text-base lg:text-lg text-text-soft mt-6 leading-relaxed max-w-2xl mx-auto"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="300"
        >
          {lead}
        </p>
      )}
    </div>

    <!-- Vertical scenario list with hairline dividers, editorial style -->
    <ul
      class="divide-y divide-border border-y border-border"
      role="list"
    >
      {scenarios.map((scenario, i) => (
        <li
          class="grid grid-cols-[auto_1fr] gap-x-5 lg:gap-x-7 gap-y-2 py-7 lg:py-8 first:pt-7 last:pb-7"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay={String(Math.min(i * 75, 700)) as "0" | "100" | "200" | "300" | "500" | "700"}
        >
          <!-- Icon disc, brand-tint, sized as an editorial bullet -->
          <span class="row-span-2 inline-flex items-center justify-center w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-brand-tint text-brand shrink-0 ring-1 ring-brand/15">
            <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPath[scenario.icon ?? "check"]} />
            </svg>
          </span>

          <!-- Title row, includes a small "0X" tracking number for editorial feel -->
          <div class="flex items-baseline gap-3 min-w-0">
            <span class="font-body text-xs font-bold tracking-widest text-brand/70 tabular-nums shrink-0">
              {pad(i)}
            </span>
            <h3 class="font-heading font-bold text-lg lg:text-xl text-text leading-snug">
              {scenario.title}
            </h3>
          </div>

          <!-- Description paragraph, indented under title for editorial alignment -->
          <p class="font-body text-base text-text-soft leading-relaxed col-start-2">
            {scenario.description}
          </p>
        </li>
      ))}
    </ul>

    <!-- Closing centered CTA pair -->
    <div
      class="mt-12 lg:mt-14 text-center"
      data-reveal
      data-reveal-from="up"
    >
      <p class="font-body text-base lg:text-lg text-text font-medium">
        Sound familiar?
      </p>
      <p class="font-body text-sm text-text-soft mt-2 max-w-md mx-auto">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor.
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center justify-center gap-3 sm:gap-4 mt-6">
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-deep text-brand-fg font-body font-bold text-base px-7 py-3.5 rounded-pill shadow-md hover:shadow-lg hover:scale-[1.02] transition-all"
        >
          {primaryCta.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href={phoneHref}
          class="inline-flex items-center justify-center gap-2 bg-transparent text-text ring-2 ring-border font-body font-bold text-base px-7 py-3.5 rounded-pill hover:ring-brand hover:text-brand transition-colors whitespace-nowrap"
        >
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd"/>
          </svg>
          Call {business.phone}
        </a>
      </div>
    </div>

  </div>
</section>
