---
/**
 * What's included — 2-col: "work-in-progress" photo left, checklist right.
 *
 * Deliberately different from the other numbered-list sections on the site
 * (CoverageDetails, HowWeWork, WhyUs, etc). The photo grounds the list in
 * actual work, and the list itself uses a standalone brand checkmark glyph
 * (no disc, no card) as the anchor so it doesn't repeat the WhyUs disc
 * pattern either.
 */
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Included {
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  serviceName: string;
  heading?: string;
  subtext?: string;
  items: Included[];
  imageSrc?: string;
  imageAlt?: string;
  imageLabel?: string;
}

const {
  eyebrow = "What's Included",
  serviceName,
  heading,
  subtext,
  items,
  imageSrc,
  imageAlt = "Service in progress",
  imageLabel = "Work Photo",
} = Astro.props;

const resolvedHeading = heading ?? `Quid accipis cum ${serviceName}.`;
const resolvedSubtext =
  subtext ??
  `Lorem ipsum dolor sit amet — omnia quae sequuntur incluso sunt in pretio pro ${serviceName}.`;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-16 items-start">

      <!-- LEFT: image placeholder -->
      <div class="lg:sticky lg:top-28">
        <ImagePlaceholder
          aspect="4/5"
          imageSrc={imageSrc}
          imageAlt={imageAlt}
          label={imageLabel}
          hint={`A photo of the team on a ${serviceName.toLowerCase()} job fits here.`}
          bloomPosition="bl"
        />
      </div>

      <!-- RIGHT: copy + checklist -->
      <div>
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
          {resolvedHeading}
        </h2>

        {resolvedSubtext && (
          <p class="font-body text-base text-text-soft mt-4 leading-relaxed max-w-lg">
            {resolvedSubtext}
          </p>
        )}

        <!-- Checklist — standalone brand checkmarks, no disc, no card -->
        <ul class="mt-10 divide-y divide-border" role="list">
          {items.map((item) => (
            <li class="grid grid-cols-[auto_1fr] gap-x-5 gap-y-1 py-6 first:pt-0">
              <svg
                class="w-6 h-6 shrink-0 text-brand row-span-2 mt-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <h3 class="font-heading text-lg text-text leading-snug">
                {item.title}
              </h3>
              <p class="font-body text-base text-text-soft leading-relaxed">
                {item.description}
              </p>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
