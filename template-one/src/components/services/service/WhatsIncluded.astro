---
/**
 * WhatsIncluded, walkthrough of what's actually delivered when the
 * customer books this service.
 *
 * Visual pattern mirrors the home-page premium-service look but flipped
 * so this section alternates with ServiceBenefits below it:
 *   LEFT  : eyebrow + heading + subtext + numbered walkthrough cards
 *           (one per inclusion).
 *   RIGHT : tall featured photo placeholder + floating circular
 *           "in-action" badge (mirrors TrustChecklist's portrait
 *           overlay treatment so the visual rhythm of the site stays
 *           consistent across pages). Overlay sticks out to the OUTER
 *           edge of the page (right side) for symmetry with other
 *           overlay sections.
 *
 * Both columns are vertically centered, so the section reads even,
 * not top-heavy. Photo column extends the full height of the content
 * column instead of getting "stranded" at the bottom.
 *
 * Companion to ServiceBenefits, this section answers "what do I get?"
 * while ServiceBenefits answers "why does this matter to me?".
 */
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Included {
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  serviceName: string;
  heading?: string;
  subtext?: string;
  items: Included[];
  imageSrc?: string;
  imageAlt?: string;
  imageLabel?: string;
}

const {
  eyebrow = "What's Included",
  serviceName,
  heading,
  subtext,
  items,
  imageSrc,
  imageAlt = "Service in progress",
  imageLabel = "WORK PHOTO",
} = Astro.props;

const resolvedHeading = heading ?? `What ${serviceName} includes.`;
// Subtext is OPTIONAL on this section, the heading + numbered walkthrough
// already explains what's included so we don't add filler text by default.
const resolvedSubtext = subtext;

const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-14 lg:gap-16 items-center">

      <!-- LEFT: eyebrow + heading + numbered cards -->
      <div class="lg:col-span-7 lg:order-1">
        {eyebrow && (
          <div
            class="inline-flex items-center gap-2.5 mb-3"
            data-reveal
            data-reveal-from="left"
          >
            <span class="block w-1 h-6 bg-brand rounded-full" aria-hidden="true"></span>
            <span class="font-body text-sm font-bold tracking-wider uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h2
          class="font-heading font-extrabold text-3xl lg:text-4xl text-text leading-[1.15] mb-4"
          data-reveal
          data-reveal-from="left"
          data-reveal-delay="100"
        >
          {resolvedHeading}
        </h2>

        {resolvedSubtext && (
          <p
            class="font-body text-base text-text-soft leading-relaxed mb-8 max-w-xl"
            data-reveal
            data-reveal-from="left"
            data-reveal-delay="200"
          >
            {resolvedSubtext}
          </p>
        )}

        <!-- Numbered walkthrough, one card per inclusion -->
        <ol class="space-y-4 mt-6" role="list">
          {items.map((item, i) => (
            <li
              class="relative bg-surface ring-1 ring-border rounded-2xl p-5 lg:p-6 flex gap-4 hover:ring-brand/40 hover:shadow-md transition-all"
              data-reveal
              data-reveal-from="left"
              data-reveal-delay={String(Math.min(300 + i * 75, 700)) as "0" | "100" | "200" | "300" | "500" | "700"}
            >
              <!-- Number badge -->
              <span class="shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-tint text-brand font-heading font-extrabold text-sm">
                {pad(i)}
              </span>

              <div class="flex-1 min-w-0">
                <h3 class="font-heading font-bold text-base lg:text-lg text-text leading-snug">
                  {item.title}
                </h3>
                <p class="font-body text-sm text-text-soft mt-1.5 leading-relaxed">
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- RIGHT: featured photo + floating "in-action" badge.
           Overlay sticks out to the OUTER edge (right) for symmetry. -->
      <div
        class="lg:col-span-5 lg:order-2 relative"
        data-reveal
        data-reveal-from="right"
      >
        <ImagePlaceholder
          aspect="4/5"
          imageSrc={imageSrc}
          imageAlt={imageAlt}
          label={imageLabel}
          hint="Service in action photo"
          bloomPosition="br"
        />
        <!-- Floating circular "in-action" overlay, sticks out to the
             right edge so the rhythm complements ServiceBenefits below
             (which has its overlay on the left). -->
        <div class="absolute -bottom-8 -right-2 lg:-right-8 w-1/2 lg:w-2/5 z-20">
          <div class="aspect-square rounded-full overflow-hidden ring-8 ring-bg shadow-xl bg-brand-tint relative">
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
              <span class="font-body text-[10px] font-bold tracking-widest uppercase text-brand">
                IN ACTION
              </span>
              <span class="font-body text-[10px] text-text-soft mt-1 max-w-[14ch] leading-tight">
                Close-up of {serviceName.toLowerCase()}
              </span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
