---
/**
 * How we work, horizontal 4-step timeline.
 *
 * Deliberately NOT another "sticky heading left + numbered list right"
 * layout, the template already uses that pattern in WhyUs, CoverageDetails,
 * and WhatsIncluded. This section gets its own visual vocabulary: a row of
 * four steps with connector line on desktop, stacking to a vertical rail
 * below lg. No cards, no shadows, just numbers, typography, and a thin
 * line that threads the steps together.
 */
interface Step {
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  steps?: Step[];
}

const {
  eyebrow = "How We Work",
  heading = "Simple process, honest result.",
  subtext =
    "Four steps from the first call to the final walkthrough. No surprises, no unexpected delays.",
  steps = [
    {
      title: "Initial contact",
      description:
        "Call or write. We respond inside an hour during business hours, often much faster.",
    },
    {
      title: "Inspection & proposal",
      description:
        "We come to the site, inspect the work, and hand you a written estimate, at no cost.",
    },
    {
      title: "The work itself",
      description:
        "Our trained, certified, and insured crew gets it done efficiently and honestly.",
    },
    {
      title: "Follow-up & warranty",
      description:
        "We follow up the next day, and every job carries a full one-year written warranty.",
    },
  ],
} = Astro.props;
---

<section class="bg-surface py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="max-w-2xl mb-16 lg:mb-20">
      {eyebrow && (
        <div class="inline-flex items-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
        </div>
      )}
      <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
        {heading}
      </h2>
      {subtext && (
        <p class="font-body text-base lg:text-lg text-text-soft mt-4 leading-relaxed">
          {subtext}
        </p>
      )}
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Horizontal connector (lg+) threads through step numbers at y=20px -->
      <div
        class="hidden lg:block absolute left-0 right-0 top-[20px] h-px bg-border"
        aria-hidden="true"
      ></div>

      <ol
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-10"
        role="list"
      >
        {steps.map((step, i) => (
          <li class="relative">
            <!-- Number disc, sits on the connector line -->
            <div
              class="relative z-10 flex items-center justify-center w-10 h-10 rounded-full bg-brand-tint text-brand font-heading text-lg leading-none ring-8 ring-surface tabular-nums"
              aria-hidden="true"
            >
              {String(i + 1).padStart(2, "0")}
            </div>

            <h3 class="mt-6 font-heading text-xl text-text leading-snug">
              {step.title}
            </h3>
            <p class="mt-3 font-body text-base text-text-soft leading-relaxed">
              {step.description}
            </p>
          </li>
        ))}
      </ol>
    </div>

  </div>
</section>
