---
/**
 * Centered close section with a phone CTA. Every page uses it as its
 * closing call-to-action, props swap the heading/subtext to match the
 * page it appears on. No secondary button: with no contact form page, a
 * "Send a Message" outline button would just dial the same number again.
 */
import { business } from "@/data/business";

interface Props {
  heading?: string;
  subtext?: string;
  phone?: string;
}

const {
  heading = "Don't see your city?",
  subtext =
    "Give us a call and we'll tell you in thirty seconds whether we can reach you, most of the time we can, even if it's not on the list.",
  phone = business.phone,
} = Astro.props;

const phoneHref = "tel:+1" + phone.replace(/\D/g, "");
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-3xl mx-auto px-6 lg:px-10 text-center">

    <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
      {heading}
    </h2>

    {subtext && (
      <p class="font-body text-base lg:text-lg text-text-soft mt-4 leading-relaxed">
        {subtext}
      </p>
    )}

    <div class="mt-8 flex justify-center">
      <a
        href={phoneHref}
        class="inline-flex items-center gap-2 bg-brand text-brand-fg font-body font-semibold text-sm px-6 py-3.5 rounded-md hover:bg-brand/90 transition-colors shadow-sm"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        Call {phone}
      </a>
    </div>

  </div>
</section>
