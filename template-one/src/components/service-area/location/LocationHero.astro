---
/**
 * Location page hero, full-bleed background image with overlay content.
 *
 * Built on the same foundation as component-lab `hero-004`:
 *   - Background image fills the section, z-index layered behind content
 *   - Dark vertical gradient for readability (heavier at the bottom)
 *   - Brand glow rising from below for warmth
 *   - Centered content: glass eyebrow badge → headline → tagline →
 *     glass trust row → dual CTAs
 *
 * The section owns its top-of-page nav clearance (pt-28 lg:pt-36 is baked
 * into the min-height / centered flex layout), and paints its own bg to
 * the edge so the translucent nav pill floats cleanly with no color break.
 *
 * The default `bgImageSrc` points at a neutral heysegment placeholder
 * asset so the template renders beautifully out of the box. Real sites
 * swap it for a local skyline / landmark / signature street view.
 */
import { business } from "@/data/business";

interface TrustBadge {
  label: string;
}

interface Props {
  eyebrow?: string;
  heading: string;
  tagline?: string;
  trustBadges?: TrustBadge[];
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  bgImageSrc?: string;
  bgImageAlt?: string;
}

const {
  eyebrow,
  heading,
  tagline,
  trustBadges = [
    { label: "Local Team" },
    { label: "Licensed & Insured" },
    { label: `Since ${business.founded}` },
  ],
  primaryCta = {
    label: `Call our ${heading} team`,
    href: "tel:+1" + business.phone.replace(/\D/g, ""),
  },
  secondaryCta = { label: "View services", href: "/services" },
  bgImageSrc = "https://assets.heysegment.com/media/aWgP0QLN_XbG.jpeg",
  bgImageAlt = "",
} = Astro.props;

const resolvedEyebrow =
  eyebrow ?? `Service Area · ${business.address.state}`;
---

<section class="relative isolate overflow-hidden bg-text text-surface">

  <!-- Background image -->
  <img
    src={bgImageSrc}
    alt={bgImageAlt}
    aria-hidden={bgImageAlt === "" ? "true" : undefined}
    class="absolute inset-0 w-full h-full object-cover object-center -z-20"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Dark overlay, heavier at the bottom for text readability -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-text/40 via-text/65 to-text/90 -z-10"
    aria-hidden="true"
  ></div>

  <!-- Brand glow rising from bottom -->
  <div
    class="absolute inset-x-0 -bottom-32 h-80 bg-brand/15 blur-3xl -z-10 pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative max-w-4xl mx-auto px-6 pt-32 sm:pt-36 lg:pt-40 pb-20 sm:pb-24 lg:pb-32 min-h-[560px] sm:min-h-[640px] lg:min-h-[720px] flex flex-col items-center justify-center text-center">

    <!-- Glass eyebrow badge -->
    <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-surface/10 backdrop-blur-sm ring-1 ring-surface/20 text-surface text-xs sm:text-sm font-semibold">
      <svg class="w-3.5 h-3.5 text-brand-tint" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
      </svg>
      <span class="tracking-wide text-surface/90">{resolvedEyebrow}</span>
    </div>

    <!-- Headline -->
    <h1
      class="mt-6 font-heading text-4xl sm:text-5xl lg:text-hero text-surface leading-[1.02] text-balance max-w-3xl"
      style="text-shadow: 0 4px 30px rgba(0,0,0,0.45);"
    >
      {heading}
    </h1>

    {tagline && (
      <p
        class="mt-5 font-body text-base sm:text-lg text-surface/85 max-w-xl leading-relaxed"
        style="text-shadow: 0 2px 16px rgba(0,0,0,0.35);"
      >
        {tagline}
      </p>
    )}

    <!-- Trust row, glass badges for legibility over the photo -->
    {trustBadges.length > 0 && (
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-2 sm:gap-2.5 text-sm text-surface">
        {trustBadges.map((badge) => (
          <li class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-text/35 backdrop-blur-md ring-1 ring-surface/20">
            <svg class="w-4 h-4 text-brand-tint shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="font-medium">{badge.label}</span>
          </li>
        ))}
      </ul>
    )}

    <!-- CTAs -->
    <div class="mt-10 w-full flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:w-auto">
      <a
        href={primaryCta.href}
        class="inline-flex items-center justify-center gap-2 bg-brand text-brand-fg font-semibold px-7 py-3.5 rounded-md hover:bg-brand/90 transition-colors shadow-lg"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex items-center justify-center gap-2 border border-surface/40 bg-surface/5 backdrop-blur-sm text-surface font-semibold px-7 py-3.5 rounded-md hover:bg-surface/10 hover:border-surface/60 transition-colors"
      >
        {secondaryCta.label}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
