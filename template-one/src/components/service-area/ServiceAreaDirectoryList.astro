---
/**
 * ServiceAreaDirectoryList, full directory of every city we cover,
 * rendered as a horizontal list of detail cards on a dark navy
 * background.
 *
 * Mirrors ServiceDirectoryList's visual treatment exactly so the
 * /service-area directory page reads as a sibling to the /services
 * directory page, just scoped to cities instead of services.
 *
 * Each row card:
 *   LEFT  : 16:9 image placeholder + city-number badge + map-pin icon disc
 *   RIGHT : "Service Area NN" eyebrow, large city name, intro paragraph,
 *           neighborhoods chip preview (if available), Learn More CTA
 *
 * Reads `business.locations`. Bottom wave divider transitions text →
 * brand so the section flows cleanly into the next teal section.
 */
import { business } from "@/data/business";
import WaveDivider from "@/components/global/WaveDivider.astro";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface LocationRow {
  name: string;
  slug: string;
  tagline?: string;
  intro?: string;
  neighborhoods?: string[];
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  /** Whether the next section is the brand-color teal (controls the bottom wave). */
  bottomTransition?: "brand" | "bg" | "none";
  /** Cap the number of neighborhood chips shown per row (avoids visual blowout). */
  neighborhoodPreviewLimit?: number;
}

const rows: LocationRow[] = business.locations.map((l) => ({
  name: l.name,
  slug: l.slug,
  tagline: l.tagline,
  intro: l.intro,
  neighborhoods: l.neighborhoods,
}));

const {
  eyebrow = "Our Coverage Map",
  heading = "Every Area We Serve",
  subtext = "Tap any city to see local reviews, projects, and the services we offer there. Don't see your area? Give us a call, we may still cover you.",
  bottomTransition = "brand",
  neighborhoodPreviewLimit = 4,
} = Astro.props;

const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="bg-text text-brand-fg relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-16 lg:pt-20 pb-20 lg:pb-28">

    <!-- Section header -->
    <div class="max-w-3xl mb-12 lg:mb-16">
      {eyebrow && (
        <p
          class="font-body text-sm font-bold tracking-widest uppercase text-brand mb-4"
          data-reveal
          data-reveal-from="up"
        >
          {eyebrow}
        </p>
      )}
      <h2
        class="font-heading font-extrabold text-4xl lg:text-5xl text-brand-fg leading-[1.1]"
        data-reveal
        data-reveal-from="up"
        data-reveal-delay="100"
      >
        {heading}
      </h2>
      {subtext && (
        <p
          class="font-body text-base lg:text-lg text-brand-fg/70 mt-5 leading-relaxed max-w-2xl"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="200"
        >
          {subtext}
        </p>
      )}
    </div>

    <!-- City rows -->
    <ul class="space-y-6 lg:space-y-8" role="list">
      {rows.map((row, i) => {
        const previewHoods = (row.neighborhoods ?? []).slice(0, neighborhoodPreviewLimit);
        const restCount = (row.neighborhoods?.length ?? 0) - previewHoods.length;

        return (
          <li
            class="group relative"
            data-reveal
            data-reveal-from="up"
            data-reveal-delay={String(Math.min(i * 100, 300)) as "0" | "100" | "200" | "300"}
          >
            <article class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-center bg-brand-fg/[0.04] hover:bg-brand-fg/[0.07] transition-colors rounded-2xl p-5 lg:p-7 ring-1 ring-brand-fg/10">

              <!-- LEFT: image placeholder with floating badges -->
              <div class="lg:col-span-5 relative">
                <ImagePlaceholder
                  aspect="16/9"
                  label={row.name.toUpperCase()}
                  hint={`Wide shot of ${row.name}`}
                  bloomPosition="tl"
                />
                <!-- City-number badge, top-left of image -->
                <span
                  class="absolute top-3 left-3 inline-flex items-center justify-center font-heading font-extrabold text-xs tracking-widest text-brand-fg bg-brand px-3 py-1.5 rounded-pill shadow-md"
                  aria-hidden="true"
                >
                  {pad(i)}
                </span>
                <!-- Map-pin icon disc, bottom-right of image -->
                <span
                  class="absolute bottom-3 right-3 inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand text-brand-fg shadow-lg ring-4 ring-text"
                >
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" />
                  </svg>
                </span>
              </div>

              <!-- RIGHT: name, copy, neighborhood preview, CTA -->
              <div class="lg:col-span-7">
                <p class="font-body text-xs font-bold tracking-widest uppercase text-brand mb-2">
                  Service Area {pad(i)}
                </p>
                <h3 class="font-heading font-extrabold text-2xl lg:text-3xl text-brand-fg leading-tight">
                  {row.name}
                </h3>
                <p class="font-body text-sm lg:text-base text-brand-fg/75 mt-3 leading-relaxed">
                  {row.intro ?? row.tagline}
                </p>

                {previewHoods.length > 0 && (
                  <div class="mt-5">
                    <p class="font-body text-[11px] font-bold tracking-widest uppercase text-brand-fg/50 mb-2">
                      Neighborhoods
                    </p>
                    <ul class="flex flex-wrap gap-2" role="list">
                      {previewHoods.map((hood) => (
                        <li>
                          <span class="inline-flex items-center gap-1.5 bg-brand-fg/10 text-brand-fg/90 font-body text-xs font-semibold px-3 py-1.5 rounded-pill ring-1 ring-brand-fg/15">
                            <svg class="w-3 h-3 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                            {hood}
                          </span>
                        </li>
                      ))}
                      {restCount > 0 && (
                        <li>
                          <span class="inline-flex items-center bg-transparent text-brand-fg/60 font-body text-xs font-semibold px-2 py-1.5">
                            + {restCount} more
                          </span>
                        </li>
                      )}
                    </ul>
                  </div>
                )}

                <div class="mt-6 flex flex-wrap items-center gap-3">
                  <a
                    href={`/service-area/${row.slug}`}
                    class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-deep text-brand-fg font-body font-bold text-sm px-6 py-3 rounded-pill shadow-md hover:shadow-lg hover:scale-[1.02] transition-all"
                  >
                    Learn More
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                  <a
                    href={business.ctaHref}
                    class="inline-flex items-center gap-1.5 font-body text-sm font-semibold text-brand-fg/80 hover:text-brand-fg transition-colors"
                  >
                    Get a Free Quote
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>

            </article>
          </li>
        );
      })}
    </ul>

  </div>

  {bottomTransition === "brand" && (
    <WaveDivider direction="down" fill="brand" bgFrom="text" />
  )}
  {bottomTransition === "bg" && (
    <WaveDivider direction="down" fill="bg" bgFrom="text" />
  )}
</section>
