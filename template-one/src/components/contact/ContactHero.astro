---
/**
 * ContactHero, dark navy page-header that matches the home / services /
 * service-area hero pattern, with a compact "small but mighty" quote
 * form sitting INSIDE the hero on the right side.
 *
 * Layout:
 *   lg+ : 7/5 split, headline LEFT, form card RIGHT
 *   sm  : single column, headline → form card
 *
 * Form fields (intentionally short):
 *   - Full Name                        (required)
 *   - Email                            (required)
 *   - Phone                            (required)
 *   - Service Needed                   (required, select pulls from
 *                                       business.services categories)
 *   - Tell us more about [service]     (optional textarea)
 *   - SMS consent checkbox             (legal-required for SMS marketing)
 *   - Submit, "Get My Quote"
 *
 * Form posts to nothing by default, the site owner wires it to their
 * CRM / email service (Formspree, Netlify Forms, custom endpoint).
 * Markup uses standard HTML form attributes so any backend works.
 *
 * Breadcrumbs render INSIDE the hero (overlay variant) so the dark
 * background extends to the very top of the page.
 */
import { business } from "@/data/business";
import Breadcrumbs from "@/components/global/Breadcrumbs.astro";

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  /** Bold visual tagline beneath the H1 pill, max ~7 words. */
  tagline?: string;
  /** Short subhead paragraph below the tagline. */
  subtext?: string;
  /** Form post target. Defaults to "#", swap for your real endpoint. */
  formAction?: string;
  /** Breadcrumb trail rendered INSIDE the hero (overlay variant). */
  breadcrumbs?: Crumb[];
}

const city = business.address?.city;
const state = business.address?.state;
const cityState = state ? `${city}, ${state}` : city ?? "Your Area";

const phoneHref = "tel:+1" + business.phone.replace(/\D/g, "");

const {
  tagline = "Lorem ipsum dolor sit amet.",
  subtext,
  formAction = "#",
  breadcrumbs,
} = Astro.props;

const h1Pill = `Contact ${business.name} in ${cityState}`;

// Service options pulled from business categories so the dropdown
// auto-stays in sync with the rest of the site.
const serviceOptions = business.services
  .filter((s) => s.tier === "category")
  .map((s) => ({ value: s.slug, label: s.name }));
---

<section class="relative bg-text overflow-hidden isolate">

  {/* Background gradient placeholder. */}
  <div class="absolute inset-0 z-0 bg-gradient-to-br from-text via-text to-brand-deep">
    <div class="absolute bottom-3 right-3 z-30 max-w-[260px] text-right">
      <p class="font-body text-[10px] uppercase tracking-widest text-brand-fg/40">
        CONTACT PAGE BACKGROUND
      </p>
      <p class="font-body text-[11px] text-brand-fg/40 mt-1 leading-snug">
        Wide hero photo, owner / team smiling, branded vehicle, or workspace
      </p>
    </div>
  </div>

  {/* Dark gradient overlay so copy + form card stay readable */}
  <div
    class="absolute inset-0 z-10 bg-gradient-to-r from-text/90 via-text/65 to-text/40"
    aria-hidden="true"
  ></div>

  {/* Breadcrumbs overlaid on the dark hero */}
  {breadcrumbs && (
    <div class="relative z-20 pt-24 lg:pt-28">
      <Breadcrumbs trail={breadcrumbs} variant="overlay" />
    </div>
  )}

  <div
    class:list={[
      "relative z-20 max-w-7xl mx-auto px-6 lg:px-10 pb-12 lg:pb-16",
      breadcrumbs ? "pt-8 lg:pt-10" : "pt-28 lg:pt-32",
    ]}
  >
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-10 items-center">

      <!-- LEFT: H1 pill + headline + subtext + secondary call-CTA. Wider
           than the form so the headline gets the visual weight. -->
      <div class="lg:col-span-7">
        <h1
          class="inline-block bg-brand text-brand-fg font-body font-bold text-xs sm:text-sm tracking-widest uppercase px-5 py-2.5 rounded-pill shadow-md mb-6"
          data-reveal
          data-reveal-from="up"
        >
          {h1Pill}
        </h1>

        <p
          class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-brand-fg leading-[1.05] tracking-tight"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="100"
        >
          {tagline}
        </p>

        {subtext && (
          <p
            class="font-body text-base text-brand-fg/80 mt-5 max-w-xl leading-relaxed"
            data-reveal
            data-reveal-from="up"
            data-reveal-delay="200"
          >
            {subtext}
          </p>
        )}

        {/* Secondary phone CTA, in case the visitor prefers to call */}
        <div
          class="mt-6 inline-flex items-center gap-3 text-brand-fg"
          data-reveal
          data-reveal-from="up"
          data-reveal-delay="300"
        >
          <span class="font-body text-sm text-brand-fg/70 uppercase tracking-widest">
            Or call now
          </span>
          <a
            href={phoneHref}
            class="inline-flex items-center gap-2 font-heading font-bold text-xl lg:text-2xl text-brand-fg hover:text-brand transition-colors"
          >
            <svg class="w-5 h-5 lg:w-6 lg:h-6 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd"/>
            </svg>
            {business.phone}
          </a>
        </div>
      </div>

      <!-- RIGHT: compact "small but mighty" quote form card -->
      <div
        class="lg:col-span-5"
        data-reveal
        data-reveal-from="up"
        data-reveal-delay="200"
      >
        <form
          action={formAction}
          method="post"
          class="bg-surface rounded-2xl shadow-2xl ring-1 ring-border p-5 lg:p-6"
          aria-label="Get a fast quote"
        >
          <!-- Form heading, compact. -->
          <div class="mb-4">
            <p class="font-body text-[11px] font-bold tracking-widest uppercase text-brand mb-1.5">
              Get a Fast Quote
            </p>
            <h2 class="font-heading font-extrabold text-xl lg:text-2xl text-text leading-tight">
              Free, no commitment.
            </h2>
            <p class="font-body text-xs text-text-soft mt-1">
              Same-day response, usually within an hour.
            </p>
          </div>

          <div class="space-y-2.5">
            <!-- Full Name -->
            <label class="block">
              <span class="font-body text-xs font-bold text-text uppercase tracking-wider">
                Full Name <span class="text-brand">*</span>
              </span>
              <input
                type="text"
                name="name"
                required
                autocomplete="name"
                placeholder="Your full name"
                class="mt-1 w-full bg-bg ring-1 ring-border rounded-lg px-3 py-2 text-base text-text placeholder:text-text-soft/60 focus:ring-2 focus:ring-brand focus:outline-none transition-shadow"
              />
            </label>

            <!-- Email -->
            <label class="block">
              <span class="font-body text-xs font-bold text-text uppercase tracking-wider">
                Email <span class="text-brand">*</span>
              </span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="mt-1 w-full bg-bg ring-1 ring-border rounded-lg px-3 py-2 text-base text-text placeholder:text-text-soft/60 focus:ring-2 focus:ring-brand focus:outline-none transition-shadow"
              />
            </label>

            <!-- Phone -->
            <label class="block">
              <span class="font-body text-xs font-bold text-text uppercase tracking-wider">
                Phone <span class="text-brand">*</span>
              </span>
              <input
                type="tel"
                name="phone"
                required
                autocomplete="tel"
                placeholder="(555) 555-5555"
                class="mt-1 w-full bg-bg ring-1 ring-border rounded-lg px-3 py-2 text-base text-text placeholder:text-text-soft/60 focus:ring-2 focus:ring-brand focus:outline-none transition-shadow"
              />
            </label>

            <!-- Service Needed -->
            <label class="block">
              <span class="font-body text-xs font-bold text-text uppercase tracking-wider">
                Service Needed <span class="text-brand">*</span>
              </span>
              <select
                name="service"
                required
                class="mt-1 w-full bg-bg ring-1 ring-border rounded-lg px-3 py-2 text-base text-text focus:ring-2 focus:ring-brand focus:outline-none transition-shadow appearance-none bg-[url('data:image/svg+xml;utf8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 20 20%22 fill=%22%2364748b%22%3E%3Cpath fill-rule=%22evenodd%22 d=%22M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z%22 clip-rule=%22evenodd%22/%3E%3C/svg%3E')] bg-no-repeat bg-[right_0.75rem_center] bg-[length:1.25em_1.25em] pr-10"
              >
                <option value="" disabled selected>Choose a service…</option>
                {serviceOptions.map((opt) => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
                <option value="not-sure">Not sure yet</option>
              </select>
            </label>

            <!-- Tell us more (optional) -->
            <label class="block">
              <span class="font-body text-xs font-bold text-text uppercase tracking-wider">
                Tell us more
                <span class="font-normal normal-case tracking-normal text-text-soft/70">(optional)</span>
              </span>
              <textarea
                name="details"
                rows="2"
                placeholder="Anything we should know about your project?"
                class="mt-1 w-full bg-bg ring-1 ring-border rounded-lg px-3 py-2 text-base text-text placeholder:text-text-soft/60 focus:ring-2 focus:ring-brand focus:outline-none transition-shadow resize-y"
              ></textarea>
            </label>
          </div>

          <!-- SMS consent -->
          <label class="flex items-start gap-2.5 mt-4 cursor-pointer">
            <input
              type="checkbox"
              name="sms_consent"
              value="yes"
              class="mt-0.5 w-4 h-4 rounded text-brand border-border focus:ring-2 focus:ring-brand cursor-pointer shrink-0"
            />
            <span class="font-body text-xs text-text-soft leading-snug">
              I agree to receive SMS messages from {business.name} about my quote. Message and data rates may apply. Reply STOP to opt out.
            </span>
          </label>

          <!-- Submit -->
          <button
            type="submit"
            class="mt-4 w-full inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-deep text-brand-fg font-body font-bold text-sm px-6 py-3 rounded-pill shadow-lg hover:shadow-xl hover:scale-[1.01] transition-all"
          >
            Get My Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>

          <p class="font-body text-[10px] text-text-soft/70 text-center mt-2.5">
            We respond same day. No spam, ever.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>
