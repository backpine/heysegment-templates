---
/**
 * Gold star rating row. Renders N stars using Google's official review gold
 * (#FBBC04). Used wherever a rating appears on the site.
 *
 * For an aggregate (e.g. "4.9 out of 5"), render 5 stars and pass the
 * descriptive label as `ariaLabel`. For an individual review rating, pass
 * `count={review.rating}` and let the default label describe it.
 */
interface Props {
  /** How many stars to render. Default 5. */
  count?: number;
  /** Optional override for the aria-label (e.g. "4.9 out of 5 stars"). */
  ariaLabel?: string;
  /** Tailwind classes for the wrapper — controls gap. */
  class?: string;
  /** Tailwind sizing for each star (e.g. "w-4 h-4"). */
  starClass?: string;
}

const {
  count = 5,
  ariaLabel,
  class: className = "flex gap-0.5",
  starClass = "w-4 h-4",
} = Astro.props;

const starPath =
  "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z";
---

<div class={className} role="img" aria-label={ariaLabel ?? `${count} out of 5 stars`}>
  {[...Array(count)].map(() => (
    <svg class={starClass} viewBox="0 0 20 20" fill="#FBBC04" aria-hidden="true">
      <path d={starPath} />
    </svg>
  ))}
</div>
