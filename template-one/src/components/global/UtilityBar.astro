---
/**
 * UtilityBar, thin dark bar that sits above the floating nav at the very
 * top of the page. Revive Services pattern: phone number on the left,
 * reviews-count and tagline messages cycling/rotating on the right.
 *
 * Hidden below md (mobile) so it doesn't crowd the floating nav pill on
 * small screens.
 */
import { business } from "@/data/business";

interface Item {
  label: string;
  href?: string;
  icon?: "phone" | "star" | "shield";
}

interface Props {
  items?: Item[];
}

const phoneHref = "tel:+1" + business.phone.replace(/\D/g, "");
const reviewTotal = business.reviews?.total ?? 0;

const {
  items = [
    {
      label: business.phone,
      href: phoneHref,
      icon: "phone",
    },
    {
      label: `${reviewTotal}+ Reviews on Google, Facebook & HomeStars`,
      icon: "star",
    },
    {
      label: business.tagline.split(", ")[0] ?? business.tagline,
      icon: "shield",
    },
  ],
} = Astro.props;

const iconPath = {
  phone: "M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z",
  star: "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z",
  shield: "M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001z",
};

const iconFor = (key: string | undefined) => iconPath[key as keyof typeof iconPath] ?? iconPath.shield;
---

<div class="hidden md:block bg-text text-brand-fg/85 fixed top-0 inset-x-0 z-[60]">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <ul class="flex items-center justify-between gap-6 py-2.5" role="list">
      {items.map((item, i) => {
        const inner = (
          <span class="inline-flex items-center gap-2 font-body text-xs lg:text-[13px]">
            <svg class="w-3.5 h-3.5 text-brand shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d={iconFor(item.icon)} clip-rule="evenodd"/>
            </svg>
            <span class={i === items.length - 1 ? "hidden xl:inline" : ""}>{item.label}</span>
          </span>
        );
        return (
          <li class={i > 0 ? "hidden lg:list-item" : ""}>
            {item.href ? (
              <a href={item.href} class="hover:text-brand-fg transition-colors">{inner}</a>
            ) : (
              inner
            )}
          </li>
        );
      })}
    </ul>
  </div>
</div>
