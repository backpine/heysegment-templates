---
/**
 * Reviews, compact social-proof band. Used as a "subtle" reviews beat
 * between two main content sections rather than as a dedicated reviews
 * section like ReviewsMasonry / ReviewsMarquee / ReviewsFeatured.
 *
 * `bg-brand-tint` gives it a warm accent without being loud. Single static
 * quote, no navigation, no animation, so it reads as one decisive trust
 * signal between the content above and below.
 */
import { business } from "@/data/business";
import GoogleLogo from "@/components/ui/GoogleLogo.astro";
import StarRating from "@/components/ui/StarRating.astro";

interface Review {
  name: string;
  rating: number;
  text: string;
}

interface Props {
  rating?: number;
  total?: number;
  review?: Review;
}

const {
  rating = business.reviews.rating,
  total = business.reviews.total,
  review = business.reviews.items[0],
} = Astro.props;
---

<section class="bg-brand-tint py-12 lg:py-16" aria-label="Customer reviews">
  <div class="max-w-6xl mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-[auto_1fr] gap-8 md:gap-12 items-center">

      <!-- LEFT: Google rating summary -->
      <div class="flex items-center gap-4 md:border-r md:border-brand/15 md:pr-12 shrink-0">
        <GoogleLogo class="w-9 h-9" />
        <div class="flex flex-col">
          <div class="flex items-center gap-1.5">
            <span class="font-heading text-xl text-text leading-none">{rating.toFixed(1)}</span>
            <StarRating ariaLabel={`${rating} out of 5 stars`} starClass="w-3.5 h-3.5" />
          </div>
          <span class="font-body text-xs text-text-soft mt-1">
            {total}+ Google reviews
          </span>
        </div>
      </div>

      <!-- RIGHT: featured quote -->
      <blockquote class="font-body text-base lg:text-lg text-text leading-relaxed">
        &ldquo;{review.text}&rdquo;
        <footer class="mt-3 font-body text-sm font-semibold text-text-soft">
          {review.name}
        </footer>
      </blockquote>

    </div>
  </div>
</section>
