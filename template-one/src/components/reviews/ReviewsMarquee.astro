---
/**
 * Reviews, horizontal scrolling ticker. Used on the /services page.
 *
 * Reviews flow continuously left-to-right in an infinite marquee. No cards
 *, each review is just stars, a short quote, and an attribution, separated
 * by a hairline vertical rule. The content loops seamlessly by rendering
 * the list twice and translating the track by -50%.
 *
 * Edge gradients fade the content to the section background on both sides
 * so reviews appear to flow in from and out into nowhere. Pauses on hover
 * and honors prefers-reduced-motion (the animation stops, leaving a static
 * row that can be swiped/scrolled by touch).
 */
import { business } from "@/data/business";
import GoogleLogo from "@/components/ui/GoogleLogo.astro";
import StarRating from "@/components/ui/StarRating.astro";

interface Review {
  name: string;
  rating: number;
  text: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  rating?: number;
  total?: number;
  reviews?: Review[];
  durationSeconds?: number;
}

const {
  eyebrow = "Google Reviews",
  heading = "What customers say about the work.",
  rating = business.reviews.rating,
  total = business.reviews.total,
  reviews = business.reviews.items,
  durationSeconds = 60,
} = Astro.props;

// Render the list twice for seamless looping; the CSS animation translates
// the track by -50%, which is exactly one full set.
const marqueeItems = [...reviews, ...reviews];
---

<section class="bg-bg py-20 lg:py-28 overflow-hidden" aria-label="Customer reviews">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 mb-14 lg:mb-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">

      <div class="max-w-xl">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}
        <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">{heading}</h2>
      </div>

      <!-- Google rating summary -->
      <div class="flex items-center gap-4">
        <GoogleLogo class="w-10 h-10" />

        <div class="flex flex-col">
          <div class="flex items-center gap-2">
            <span class="font-heading text-2xl text-text leading-none">{rating.toFixed(1)}</span>
            <StarRating ariaLabel={`${rating} out of 5 stars`} />
          </div>
          <span class="font-body text-sm text-text-soft mt-1">
            {total}+ reviews on <span class="font-semibold text-text">Google</span>
          </span>
        </div>
      </div>

    </div>
  </div>

  <!-- Marquee viewport, full-bleed so the track can run past the page gutter -->
  <div class="relative" data-marquee>
    <!-- Edge fades (match bg-bg so the strip appears to dissolve) -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-24 sm:w-32 bg-gradient-to-r from-bg to-transparent z-10"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 w-24 sm:w-32 bg-gradient-to-l from-bg to-transparent z-10"
      aria-hidden="true"
    ></div>

    <!-- The track itself, doubled content for seamless looping -->
    <div
      class="flex items-stretch gap-10 sm:gap-14 w-max marquee-track"
      style={`--marquee-duration: ${durationSeconds}s;`}
    >
      {marqueeItems.map((review) => (
        <article class="flex items-center gap-5 w-[22rem] sm:w-[26rem] shrink-0">
          <StarRating count={review.rating} class="flex gap-0.5 shrink-0" />

          <!-- Divider -->
          <span class="w-px self-stretch bg-border shrink-0" aria-hidden="true"></span>

          <!-- Quote + attribution -->
          <div class="min-w-0">
            <p class="font-body text-sm text-text leading-relaxed line-clamp-3">
              &ldquo;{review.text}&rdquo;
            </p>
            <p class="font-body text-xs font-semibold text-text-soft mt-2">
              {review.name}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Read all link -->
  <div class="max-w-7xl mx-auto px-6 lg:px-10 mt-12 text-center">
    <a
      href="https://www.google.com/maps"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
    >
      Read all reviews on Google
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee-scroll var(--marquee-duration, 60s) linear infinite;
    will-change: transform;
  }

  /* Track is twice the content width (rendered twice). Translating by -50%
     lands exactly at the start of the duplicate, producing a seamless loop. */
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  [data-marquee]:hover .marquee-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
    [data-marquee] {
      overflow-x: auto;
      scroll-snap-type: x proximity;
    }
    [data-marquee] > .marquee-track > * {
      scroll-snap-align: start;
    }
  }
</style>
