---
/**
 * About page header, two-up with copy on the left and a storefront /
 * team photo placeholder on the right.
 *
 * Mirrors the existing utility-header pattern (services, service-area)
 * so the template's top-of-page beats feel consistent across sections.
 *
 * Owns its own top clearance (pt-28 lg:pt-36) for the floating nav pill.
 */
import { business } from "@/data/business";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  stats?: Stat[];
  imageSrc?: string;
  imageAlt?: string;
  imageLabel?: string;
}

const {
  eyebrow = "About Us",
  heading = "Local crew, high standards.",
  subtext =
    "Family, not factory. Founded in 2008, with technicians who are fully licensed and insured, and work finished without shortcuts. This is what hiring real local pros looks like.",
  stats = [
    { value: `${new Date().getFullYear() - business.founded}+`, label: "Years in business" },
    { value: "8,200+", label: "Jobs completed" },
    { value: "4.9★", label: "Google rating" },
  ],
  imageSrc,
  imageAlt = "Our storefront",
  imageLabel = "STOREFRONT PHOTO",
} = Astro.props;
---

<section class="relative overflow-hidden bg-surface">
  <!-- Ambient brand glow -->
  <div
    class="hidden lg:block absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1100px] h-[700px] rounded-full bg-brand/[0.05] blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-28 lg:pt-36 pb-16 lg:pb-24">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">

      <!-- Copy -->
      <div class="lg:col-span-6">

        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-5">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h1 class="font-heading text-3xl sm:text-4xl lg:text-hero text-text leading-[1.05] tracking-tight">
          {heading}
        </h1>

        {subtext && (
          <p class="font-body text-base lg:text-lg text-text-soft mt-6 leading-relaxed max-w-xl">
            {subtext}
          </p>
        )}

        {stats.length > 0 && (
          <dl class="mt-10 pt-8 border-t border-border flex flex-wrap gap-x-10 gap-y-5">
            {stats.map((stat) => (
              <div>
                <dt class="font-heading text-2xl text-text leading-none">{stat.value}</dt>
                <dd class="font-body text-sm text-text-soft mt-2">{stat.label}</dd>
              </div>
            ))}
          </dl>
        )}

      </div>

      <!-- Image placeholder -->
      <div class="lg:col-span-6">
        <ImagePlaceholder
          aspect="5/4"
          imageSrc={imageSrc}
          imageAlt={imageAlt}
          label={imageLabel}
          hint="Storefront, team, or fleet"
          bloomPosition="tl"
        />
      </div>

    </div>
  </div>
</section>
