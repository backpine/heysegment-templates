---
/**
 * FAQList — categorized accordion FAQ using native <details>/<summary>.
 *
 * Zero JavaScript. Each category becomes a small uppercase label over a
 * divided list of questions. The accordion reveals the answer with a
 * rotating plus glyph. No cards — just hairline dividers and typography.
 *
 * The page-level "still have questions?" close lives in a separate
 * CheckAvailability section, not inside this component, so this file
 * stays focused on rendering the question list.
 */
import { business } from "@/data/business";

interface Question {
  question: string;
  answer: string;
}

interface FAQCategory {
  category: string;
  questions: Question[];
}

interface Props {
  categories?: FAQCategory[];
}

const { categories = business.faqs } = Astro.props;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-3xl mx-auto px-6 lg:px-10">

    <div class="space-y-14 lg:space-y-16">
      {categories.map((cat) => (
        <div>
          <!-- Category label -->
          <h2 class="font-body text-xs font-semibold tracking-widest uppercase text-brand pb-4 border-b border-brand/30 mb-2">
            {cat.category}
          </h2>

          <!-- Questions -->
          <div class="divide-y divide-border">
            {cat.questions.map((item) => (
              <details class="group">
                <summary class="flex items-start justify-between gap-4 cursor-pointer list-none py-5">
                  <span class="font-body font-semibold text-base text-text group-open:text-brand transition-colors pr-2">
                    {item.question}
                  </span>
                  <span class="shrink-0 mt-0.5" aria-hidden="true">
                    <svg
                      class="w-5 h-5 text-text-soft group-open:rotate-45 group-open:text-brand transition-all duration-200"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                  </span>
                </summary>
                <p class="font-body text-base text-text-soft leading-relaxed pb-6 pr-9">
                  {item.answer}
                </p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
