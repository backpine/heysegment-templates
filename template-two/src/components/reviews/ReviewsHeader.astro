---
/**
 * Reviews page header — text + rating-as-visual.
 *
 * Instead of an image placeholder, the aggregate Google rating is the hero
 * visual: a large 4.9 figure, gold stars, and "on Google" attribution laid
 * out on the right side of a two-up layout. The data IS the header.
 *
 * Owns its own top clearance (pt-28 lg:pt-36) for the floating nav pill.
 */
import { business } from "@/data/business";
import GoogleLogo from "@/components/ui/GoogleLogo.astro";
import StarRating from "@/components/ui/StarRating.astro";

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  rating?: number;
  total?: number;
  fiveStarPct?: number;
}

const {
  eyebrow = "Reviews",
  heading = "Voces clientium nostrorum.",
  subtext =
    "Lorem ipsum dolor sit amet — every review below was left by a paying customer on Google. We never edit or cherry-pick.",
  rating = business.reviews.rating,
  total = business.reviews.total,
  fiveStarPct = 94,
} = Astro.props;
---

<section class="relative overflow-hidden bg-surface">
  <!-- Ambient brand glow -->
  <div
    class="hidden lg:block absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1100px] h-[700px] rounded-full bg-brand/[0.05] blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-28 lg:pt-36 pb-16 lg:pb-24">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-14 items-center">

      <!-- Copy -->
      <div class="lg:col-span-7">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-5">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h1 class="font-heading text-3xl sm:text-4xl lg:text-hero text-text leading-[1.05] tracking-tight">
          {heading}
        </h1>

        {subtext && (
          <p class="font-body text-base lg:text-lg text-text-soft mt-6 leading-relaxed max-w-xl">
            {subtext}
          </p>
        )}
      </div>

      <!-- Rating-as-visual -->
      <aside class="lg:col-span-5">
        <div class="flex flex-col items-start lg:items-end">

          <!-- Google branding -->
          <div class="inline-flex items-center gap-2.5 mb-5">
            <GoogleLogo class="w-6 h-6" />
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-text-soft">
              Google Reviews
            </span>
          </div>

          <!-- Big rating -->
          <div class="flex items-baseline gap-3">
            <span class="font-heading text-[5rem] lg:text-[6.5rem] text-text leading-none tabular-nums">
              {rating.toFixed(1)}
            </span>
            <span class="font-body text-lg text-text-soft">/ 5</span>
          </div>

          <StarRating
            ariaLabel={`${rating} out of 5 stars`}
            class="flex gap-1 mt-4"
            starClass="w-6 h-6"
          />

          <!-- Stats row -->
          <dl class="mt-8 pt-6 border-t border-border w-full flex flex-wrap gap-x-8 gap-y-4 lg:justify-end">
            <div>
              <dt class="font-heading text-xl text-text leading-none">{total}+</dt>
              <dd class="font-body text-sm text-text-soft mt-1.5">Reviews</dd>
            </div>
            <div>
              <dt class="font-heading text-xl text-text leading-none">{fiveStarPct}%</dt>
              <dd class="font-body text-sm text-text-soft mt-1.5">Five-star</dd>
            </div>
            <div>
              <dt class="font-heading text-xl text-text leading-none">{new Date().getFullYear() - business.founded}+</dt>
              <dd class="font-body text-sm text-text-soft mt-1.5">Years reviewed</dd>
            </div>
          </dl>

        </div>
      </aside>

    </div>
  </div>
</section>
