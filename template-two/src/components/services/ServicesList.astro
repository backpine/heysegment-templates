---
/**
 * Services list — the full catalog for the /services overview page.
 *
 * 2-column editorial grid (vs. the home page's 3-column `PopularServices`)
 * to give each item more breathing room and make this feel like a proper
 * catalog page rather than a summary teaser.
 *
 * `Learn more →` only renders on services that have a matching entry in
 * `business.serviceDetails` — the home page does the same, so no link on
 * the site ever points at a 404.
 */
import { business } from "@/data/business";

interface Service {
  name: string;
  slug: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  services?: Service[];
}

const {
  eyebrow = "All Services",
  heading = "Quod facimus, facimus bene.",
  subtext =
    "Lorem ipsum dolor sit amet, consectetur adipiscing elit — every service backed by the same crew, pricing, and guarantee.",
  services = business.services,
} = Astro.props;

const detailSlugs = new Set(business.serviceDetails.map((d) => d.slug));
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="max-w-2xl mb-14 lg:mb-20">
      {eyebrow && (
        <div class="inline-flex items-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
        </div>
      )}
      <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">{heading}</h2>
      {subtext && (
        <p class="font-body text-base lg:text-lg text-text-soft mt-4 leading-relaxed">
          {subtext}
        </p>
      )}
    </div>

    <!-- 2-col editorial grid — no cards, hairline-anchored rows -->
    <ul class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-14" role="list">
      {services.map((service, i) => (
        <li class="pt-6 border-t-2 border-brand/25">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-heading text-xl text-brand leading-none tabular-nums">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft">
              Service
            </span>
          </div>

          <h3 class="font-heading text-2xl text-text leading-snug">
            {service.name}
          </h3>

          <p class="font-body text-base text-text-soft mt-3 leading-relaxed">
            {service.description}
          </p>

          {detailSlugs.has(service.slug) && (
            <a
              href={`/services/${service.slug}`}
              class="inline-flex items-center gap-1.5 mt-6 font-body text-sm font-semibold text-brand hover:gap-2.5 transition-all duration-150"
              aria-label={`Learn more about ${service.name}`}
            >
              Learn more about {service.name}
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          )}
        </li>
      ))}
    </ul>

  </div>
</section>
