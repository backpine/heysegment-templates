---
/**
 * Service map + city list — the core of the service area page.
 *
 * Map on the left, checkmarked city list on the right. Map loads client-side
 * via heysegment-sdk. Cities read from business.serviceAreas by default; each
 * is rendered as an uncarded row with a small brand check glyph.
 */
import { business } from "@/data/business";

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  cities?: string[];
}

const {
  eyebrow = "Coverage Map",
  heading = "Omnia loca quae servimus.",
  subtext =
    "Ut enim ad minim veniam, quis nostrud exercitation. Every city below gets the same response time and the same pricing as our home base.",
  cities = business.serviceAreas,
} = Astro.props;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <!-- Map -->
      <div>
        <div
          id="service-area-map"
          class="relative aspect-[4/3] lg:aspect-square rounded-xl overflow-hidden ring-1 ring-border/60 bg-surface"
        >
          <div class="absolute inset-0 flex items-center justify-center text-text-soft text-sm">
            <span>Loading map…</span>
          </div>
        </div>
      </div>

      <!-- City list -->
      <div class="lg:pt-2">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
          {heading}
        </h2>

        {subtext && (
          <p class="font-body text-base text-text-soft mt-4 leading-relaxed max-w-lg">
            {subtext}
          </p>
        )}

        <ul class="mt-10 grid grid-cols-2 gap-x-6 gap-y-3" role="list">
          {cities.map((city) => (
            <li class="flex items-center gap-2.5">
              <span
                class="flex items-center justify-center w-5 h-5 rounded-full bg-brand-tint shrink-0"
                aria-hidden="true"
              >
                <svg class="w-3 h-3 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </span>
              <span class="font-body text-sm text-text">{city}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<script>
  import { siteInfo } from "@/lib/sdk";

  const container = document.getElementById("service-area-map");
  if (container) {
    const { data, error } = await siteInfo.getMapUrl();

    if (error) {
      container.innerHTML = `<div class="absolute inset-0 flex items-center justify-center text-text-soft text-sm"><span>${error.message}</span></div>`;
    } else if (data.mapUrl === null) {
      container.style.display = "none";
    } else {
      container.innerHTML = `<iframe title="Service area map" width="100%" height="100%" style="border:0; display:block;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" src="${data.mapUrl}"></iframe>`;
    }
  }
</script>
