---
/**
 * Local presence — "why we're good here" copy on the left, live map of the
 * business location on the right. Reinforces that the team is genuinely
 * nearby, not a distant franchise lifting a pin onto the area.
 *
 * Map loads client-side via heysegment-sdk (same pattern as Footer, etc).
 */
import { business } from "@/data/business";

interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  areaName: string;
  heading?: string;
  body?: string;
  stats?: Stat[];
  baseCity?: string;
}

const {
  eyebrow = "Local Presence",
  areaName,
  heading,
  body,
  stats = [
    { value: "< 2 hrs", label: "Typical response" },
    { value: "15+", label: "Years serving" },
    { value: "24/7", label: "Emergency line" },
  ],
  baseCity = business.address.city,
} = Astro.props;

const resolvedHeading = heading ?? `Proximi ${areaName}.`;
const resolvedBody =
  body ??
  `Lorem ipsum dolor sit amet — grex noster ex ${baseCity} dispatcha est, paratus ad ${areaName} intra horas. Consectetur adipiscing elit, sed do eiusmod tempor incididunt.`;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- LEFT: copy + stats -->
      <div class="lg:pt-2">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h2 class="font-heading text-3xl lg:text-4xl text-text leading-tight">
          {resolvedHeading}
        </h2>

        <p class="font-body text-base lg:text-lg text-text-soft mt-5 leading-relaxed max-w-lg">
          {resolvedBody}
        </p>

        {stats.length > 0 && (
          <dl class="mt-10 pt-8 border-t border-border flex flex-wrap gap-x-10 gap-y-5">
            {stats.map((stat) => (
              <div>
                <dt class="font-heading text-2xl text-text leading-none">{stat.value}</dt>
                <dd class="font-body text-sm text-text-soft mt-2">{stat.label}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>

      <!-- RIGHT: map -->
      <div>
        <div
          id="local-presence-map"
          class="relative aspect-[4/3] lg:aspect-square rounded-xl overflow-hidden ring-1 ring-border/60 bg-surface"
        >
          <div class="absolute inset-0 flex items-center justify-center text-text-soft text-sm">
            <span>Loading map…</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { siteInfo } from "@/lib/sdk";

  const container = document.getElementById("local-presence-map");
  if (container) {
    const { data, error } = await siteInfo.getMapUrl();

    if (error) {
      container.innerHTML = `<div class="absolute inset-0 flex items-center justify-center text-text-soft text-sm"><span>${error.message}</span></div>`;
    } else if (data.mapUrl === null) {
      container.style.display = "none";
    } else {
      container.innerHTML = `<iframe title="Our location" width="100%" height="100%" style="border:0; display:block;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" src="${data.mapUrl}"></iframe>`;
    }
  }
</script>
